do_uninstall() {
    log_step "卸载 FoxWAF"
    log_warn "服务将停止，数据保留在 ${INSTALL_DIR}"
    confirm "确认卸载？" || { log_dim "已取消"; return 0; }
    do_stop 2>/dev/null
    if is_docker; then
        cd "$INSTALL_DIR" && docker compose down --rmi all 2>/dev/null || true
    fi
    rm -f /usr/local/bin/foxwaf
    log_ok "已卸载"
    log_dim "如需彻底删除数据: rm -rf ${INSTALL_DIR}"
}

do_version() {
    local raw clean
    raw=$(_live_version)
    if [[ -z "$raw" ]]; then
        echo "FoxWAF unknown"
        return
    fi
    clean=$(_live_version_clean "$raw")
    echo "FoxWAF ${clean}"
}

