#!/bin/bash
# FoxWAF 管理工具
# 用法: foxwaf {start|stop|restart|status|logs|update|export|import|uninstall|version}

INSTALL_DIR="/data/foxwaf"
MODE="docker"
CONTAINER_NAME="foxwaf"

COLOR_RED='\033[0;31m'
COLOR_GREEN='\033[0;32m'
COLOR_YELLOW='\033[1;33m'
COLOR_CYAN='\033[0;36m'
COLOR_RESET='\033[0m'

log_info()  { echo -e "${COLOR_GREEN}[INFO]${COLOR_RESET}  $*"; }
log_error() { echo -e "${COLOR_RED}[ERROR]${COLOR_RESET} $*"; }
log_warn()  { echo -e "${COLOR_YELLOW}[WARN]${COLOR_RESET}  $*"; }

detect_mode() {
    if [[ -f "${INSTALL_DIR}/docker-compose.yml" ]]; then
        MODE="docker"
    elif systemctl is-enabled foxwaf &>/dev/null; then
        MODE="bare"
    fi
}

do_start() {
    detect_mode
    if [[ "$MODE" == "docker" ]]; then
        cd "$INSTALL_DIR" && docker compose up -d
    else
        cd "$INSTALL_DIR" && nohup ./waf > waf.log 2>&1 &
        echo $! > "${INSTALL_DIR}/waf.pid"
    fi
    log_info "FoxWAF 已启动"
}

do_stop() {
    detect_mode
    if [[ "$MODE" == "docker" ]]; then
        cd "$INSTALL_DIR" && docker compose down 2>/dev/null || docker stop "$CONTAINER_NAME" 2>/dev/null || true
    else
        if [[ -f "${INSTALL_DIR}/waf.pid" ]]; then
            kill "$(cat "${INSTALL_DIR}/waf.pid")" 2>/dev/null || true
            rm -f "${INSTALL_DIR}/waf.pid"
        fi
        pkill -f "${INSTALL_DIR}/waf" 2>/dev/null || true
    fi
    log_info "FoxWAF 已停止"
}

do_restart() {
    do_stop
    sleep 1
    do_start
}

do_status() {
    detect_mode
    echo -e "${COLOR_CYAN}═══════════════════ FoxWAF 状态 ═══════════════════${COLOR_RESET}"
    echo ""
    if [[ -f "${INSTALL_DIR}/.version" ]]; then
        echo -e "  版本:     $(cat "${INSTALL_DIR}/.version")"
    fi
    echo -e "  安装目录: ${INSTALL_DIR}"
    echo -e "  运行模式: ${MODE}"
    echo ""

    local running=false
    if [[ "$MODE" == "docker" ]]; then
        local status
        status=$(docker ps --filter "name=${CONTAINER_NAME}" --format '{{.Status}}' 2>/dev/null)
        if echo "$status" | grep -qi "up"; then
            running=true
            echo -e "  状态:     ${COLOR_GREEN}运行中${COLOR_RESET}"
            docker ps --filter "name=${CONTAINER_NAME}" --format "  容器ID:   {{.ID}}" 2>/dev/null
            docker ps --filter "name=${CONTAINER_NAME}" --format "  运行时间: {{.RunningFor}}" 2>/dev/null
        fi
    else
        local pid=""
        [[ -f "${INSTALL_DIR}/waf.pid" ]] && pid=$(cat "${INSTALL_DIR}/waf.pid")
        if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
            running=true
            echo -e "  状态:     ${COLOR_GREEN}运行中${COLOR_RESET}"
            echo -e "  PID:      $pid"
            local mem
            mem=$(ps -p "$pid" -o rss= 2>/dev/null | awk '{printf "%.1f MB", $1/1024}')
            echo -e "  内存:     $mem"
        fi
    fi

    if [[ "$running" == "false" ]]; then
        echo -e "  状态:     ${COLOR_RED}已停止${COLOR_RESET}"
    fi

    if [[ -f "${INSTALL_DIR}/conf.yaml" ]]; then
        local port entry
        port=$(grep -oP 'port:\s*\K\d+' "${INSTALL_DIR}/conf.yaml" 2>/dev/null | head -1)
        entry=$(grep -oP 'secureentry:\s*"\K[^"]+' "${INSTALL_DIR}/conf.yaml" 2>/dev/null | head -1)
        if [[ -n "$port" ]]; then
            echo -e "  管理面板: http://localhost:${port}/${entry:-foxadmin}"
        fi
    fi
    echo ""
    echo -e "${COLOR_CYAN}══════════════════════════════════════════════════${COLOR_RESET}"
}

do_logs() {
    detect_mode
    if [[ "$MODE" == "docker" ]]; then
        docker logs -f --tail 100 "$CONTAINER_NAME" 2>/dev/null || \
            (cd "$INSTALL_DIR" && docker compose logs -f --tail 100)
    else
        if [[ -f "${INSTALL_DIR}/waf.log" ]]; then
            tail -f -n 100 "${INSTALL_DIR}/waf.log"
        else
            log_error "日志文件不存在"
        fi
    fi
}

do_export() {
    local backup_dir="${INSTALL_DIR}/backup"
    mkdir -p "$backup_dir"
    local timestamp
    timestamp=$(date +%Y%m%d_%H%M%S)
    local backup_file="${backup_dir}/foxwaf-backup-${timestamp}.tar.gz"

    log_info "开始导出备份..."

    local tmpdir
    tmpdir=$(mktemp -d)

    for item in conf.yaml source.enc waf .version docker-compose.yml; do
        [[ -f "${INSTALL_DIR}/${item}" ]] && cp -a "${INSTALL_DIR}/${item}" "$tmpdir/"
    done

    for subdir in data certificates plugins history; do
        [[ -d "${INSTALL_DIR}/${subdir}" ]] && cp -a "${INSTALL_DIR}/${subdir}" "$tmpdir/"
    done

    for dbfile in "${INSTALL_DIR}"/*.db; do
        [[ -f "$dbfile" ]] && cp -a "$dbfile" "$tmpdir/"
    done

    detect_mode
    if [[ "$MODE" == "docker" ]]; then
        log_info "导出 Docker 镜像..."
        local image_name
        image_name=$(docker inspect "$CONTAINER_NAME" --format '{{.Config.Image}}' 2>/dev/null)
        if [[ -n "$image_name" ]]; then
            docker save "$image_name" -o "${tmpdir}/docker-image.tar" 2>/dev/null || log_warn "Docker 镜像导出失败"
        fi
    fi

    tar -czf "$backup_file" -C "$tmpdir" .
    rm -rf "$tmpdir"

    local size
    size=$(du -sh "$backup_file" | awk '{print $1}')
    log_info "备份完成: $backup_file ($size)"
}

do_import() {
    local backup_file="${1:-}"
    if [[ -z "$backup_file" ]]; then
        local latest
        latest=$(ls -t "${INSTALL_DIR}/backup"/foxwaf-backup-*.tar.gz 2>/dev/null | head -1)
        if [[ -z "$latest" ]]; then
            log_error "请指定备份文件路径: foxwaf import <path>"
            return 1
        fi
        backup_file="$latest"
        log_info "使用最新备份: $backup_file"
    fi

    if [[ ! -f "$backup_file" ]]; then
        log_error "备份文件不存在: $backup_file"
        return 1
    fi

    log_info "开始恢复: $backup_file"
    log_warn "将覆盖现有数据，建议先执行 foxwaf export"
    read -rp "确认恢复? [y/N] " confirm
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
        log_info "已取消"
        return 0
    fi

    do_stop 2>/dev/null || true

    local tmpdir
    tmpdir=$(mktemp -d)
    tar -xzf "$backup_file" -C "$tmpdir"
    mkdir -p "$INSTALL_DIR"

    for item in "$tmpdir"/*; do
        local name
        name=$(basename "$item")
        [[ "$name" == "docker-image.tar" ]] && continue
        cp -a "$item" "${INSTALL_DIR}/"
    done

    if [[ -f "${tmpdir}/docker-image.tar" ]]; then
        log_info "导入 Docker 镜像..."
        docker load -i "${tmpdir}/docker-image.tar" 2>/dev/null || log_warn "Docker 镜像导入失败"
    fi

    chmod 755 "${INSTALL_DIR}/waf" 2>/dev/null || true
    rm -rf "$tmpdir"

    log_info "恢复完成"
    do_start
}

FOXWAF_SERVER="${FOXWAF_SERVER:-server.foxwaf.cn}"
MIRROR_REPOS_GITHUB="https://github.com/kabubu/storage"
MIRROR_REPOS_GITCODE="https://gitcode.com/kabubu/storage"
MIRROR_REPOS_GITEE="https://gitee.com/kabubu/storage"
MIRROR_REPOS_GITLAB="https://gitlab.com/kabubu/storage"

build_download_url() {
    local repo="$1" version="$2" file="$3" platform="$4"
    local tag="v${version}"
    case "$platform" in
        gitlab) echo "${repo}/-/releases/${tag}/downloads/${file}" ;;
        *)      echo "${repo}/releases/download/${tag}/${file}" ;;
    esac
}

download_update_file() {
    local file="$1" dest="$2" version="$3"
    for m in gitcode github gitee gitlab; do
        local repo=""
        case "$m" in
            github)  repo="$MIRROR_REPOS_GITHUB" ;;
            gitcode) repo="$MIRROR_REPOS_GITCODE" ;;
            gitee)   repo="$MIRROR_REPOS_GITEE" ;;
            gitlab)  repo="$MIRROR_REPOS_GITLAB" ;;
        esac
        [[ -z "$repo" ]] && continue
        local url
        url=$(build_download_url "$repo" "$version" "$file" "$m")
        log_info "尝试: [$m] $file"
        if curl -fSL --connect-timeout 15 --max-time 300 -o "$dest" "$url" 2>/dev/null; then
            log_info "下载成功: $file ($m)"
            return 0
        fi
    done
    local fallback="http://${FOXWAF_SERVER}:8080/release/${version}/${file}"
    log_info "回退服务端: $file"
    if curl -fSL --connect-timeout 15 --max-time 300 -o "$dest" "$fallback" 2>/dev/null; then
        log_info "下载成功: $file (服务端)"
        return 0
    fi
    return 1
}

do_update() {
    log_info "检查更新..."
    local current_version="0.0.0"
    [[ -f "${INSTALL_DIR}/.version" ]] && current_version=$(cat "${INSTALL_DIR}/.version")

    local resp
    resp=$(curl -s --connect-timeout 10 -X POST "http://${FOXWAF_SERVER}:8080/api/update/check" \
        -H "Content-Type: application/json" \
        -d "{\"currentVersion\":\"${current_version}\"}" 2>/dev/null) || true

    if [[ -z "$resp" ]]; then
        log_error "无法连接更新服务器"
        return 1
    fi

    local has_update
    has_update=$(echo "$resp" | grep -oP '"hasUpdate"\s*:\s*\K(true|false)' | head -1)
    if [[ "$has_update" != "true" ]]; then
        log_info "当前已是最新版本: $current_version"
        return 0
    fi

    local new_version features
    new_version=$(echo "$resp" | grep -oP '"version"\s*:\s*"[^"]*"' | head -1 | grep -oP '"[^"]*"$' | tr -d '"')
    features=$(echo "$resp" | grep -oP '"features"\s*:\s*"[^"]*"' | head -1 | grep -oP '"[^"]*"$' | tr -d '"')

    echo ""
    echo -e "${COLOR_CYAN}发现新版本: ${new_version}${COLOR_RESET}"
    [[ -n "${features:-}" ]] && echo -e "  特性: ${features}"
    echo -e "  当前: ${current_version}"
    echo ""
    read -rp "是否更新? [y/N] " confirm
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
        log_info "已取消更新"
        return 0
    fi

    log_info "备份当前版本..."
    cp "${INSTALL_DIR}/waf" "${INSTALL_DIR}/waf.bak" 2>/dev/null || true
    cp "${INSTALL_DIR}/source.enc" "${INSTALL_DIR}/source.enc.bak" 2>/dev/null || true

    local tmpdir
    tmpdir=$(mktemp -d)

    log_info "下载新版本 ${new_version} ..."
    if download_update_file "waf" "${tmpdir}/waf" "$new_version" && \
       download_update_file "source.enc" "${tmpdir}/source.enc" "$new_version"; then

        download_update_file "waf.md5" "${tmpdir}/waf.md5" "$new_version" 2>/dev/null || true
        download_update_file "source.enc.md5" "${tmpdir}/source.enc.md5" "$new_version" 2>/dev/null || true

        local ok=true
        for pair in "waf:waf.md5" "source.enc:source.enc.md5"; do
            local f="${pair%%:*}" mf="${pair##*:}"
            if [[ -f "${tmpdir}/${mf}" ]]; then
                local expected actual
                expected=$(awk '{print $1}' "${tmpdir}/${mf}" | tr '[:upper:]' '[:lower:]')
                actual=$(md5sum "${tmpdir}/${f}" | awk '{print $1}')
                if [[ "$expected" != "$actual" ]]; then
                    log_error "${f} MD5 校验失败"
                    ok=false
                fi
            fi
        done

        if [[ "$ok" == "true" ]]; then
            do_stop 2>/dev/null || true
            cp "${tmpdir}/waf" "${INSTALL_DIR}/waf"
            chmod 755 "${INSTALL_DIR}/waf"
            cp "${tmpdir}/source.enc" "${INSTALL_DIR}/source.enc"
            echo "$new_version" > "${INSTALL_DIR}/.version"
            do_start
            log_info "更新成功: ${current_version} → ${new_version}"
            rm -f "${INSTALL_DIR}/waf.bak" "${INSTALL_DIR}/source.enc.bak"
        else
            log_error "校验失败，保持当前版本"
        fi
    else
        log_error "下载失败，保持当前版本"
    fi
    rm -rf "$tmpdir"
}

do_uninstall() {
    log_warn "即将卸载 FoxWAF"
    read -rp "确认卸载? 数据将被保留在 ${INSTALL_DIR} [y/N] " confirm
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
        log_info "已取消"
        return 0
    fi

    do_stop 2>/dev/null || true
    detect_mode
    if [[ "$MODE" == "docker" ]]; then
        cd "$INSTALL_DIR" && docker compose down --rmi local 2>/dev/null || true
    fi

    rm -f /usr/local/bin/foxwaf
    log_info "FoxWAF 已卸载 (数据保留在 ${INSTALL_DIR})"
    log_info "如需彻底删除: rm -rf ${INSTALL_DIR}"
}

do_version() {
    if [[ -f "${INSTALL_DIR}/.version" ]]; then
        echo "FoxWAF $(cat "${INSTALL_DIR}/.version")"
    else
        echo "FoxWAF (版本未知)"
    fi
}

show_usage() {
    echo -e "${COLOR_CYAN}FoxWAF${COLOR_RESET} 管理工具"
    echo ""
    echo "用法: foxwaf <命令>"
    echo ""
    echo "命令:"
    echo "  start       启动 FoxWAF"
    echo "  stop        停止 FoxWAF"
    echo "  restart     重启 FoxWAF"
    echo "  status      查看运行状态"
    echo "  logs        查看实时日志"
    echo "  update      检查并应用更新"
    echo "  export      导出数据备份"
    echo "  import      从备份恢复 [foxwaf import <file>]"
    echo "  uninstall   卸载 FoxWAF"
    echo "  version     查看版本"
}

case "${1:-}" in
    start)     do_start ;;
    stop)      do_stop ;;
    restart)   do_restart ;;
    status)    do_status ;;
    logs)      do_logs ;;
    export)    do_export ;;
    import)    do_import "${2:-}" ;;
    update)    do_update ;;
    uninstall) do_uninstall ;;
    version)   do_version ;;
    -h|--help) show_usage ;;
    *)         show_usage; exit 1 ;;
esac
