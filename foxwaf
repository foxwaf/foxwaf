# ║  实时状态刷新（核心修复）                                       ║
# ╚═══════════════════════════════════════════════════════════════╝

do_status_live() {
    # ── 退出清理 ──────────────────────────────────────────────────
    # 必须同时写 stdout 和 /dev/tty：
    #   - Ctrl+C 时 bash 在 sleep 子进程退出后才跑 trap，stdout 缓冲可能已刷不到终端
    #   - /dev/tty 直连控制终端，不受重定向/缓冲影响，是恢复光标最可靠的路径
    _status_live_cleanup() {
        trap - INT TERM HUP EXIT
        # 两条路都写，哪条通哪条生效
        local _SHOW_CURSOR=$'\033[?25h'
        printf '%s' "$_SHOW_CURSOR"                                          # stdout
        tput cnorm 2>/dev/null || true                                       # stdout (terminfo)
        if [[ -w /dev/tty ]]; then
            printf '%s' "$_SHOW_CURSOR" >/dev/tty                           # /dev/tty
            tput cnorm >/dev/tty 2>/dev/null || true                        # /dev/tty (terminfo)
            stty sane </dev/tty 2>/dev/null || true                         # 修复行规约
        fi
    }
    trap '_status_live_cleanup; exit 0' INT TERM HUP
    trap '_status_live_cleanup'         EXIT

    # ── 隐藏光标（同样双写保证生效）────────────────────────────────
    local _HIDE_CURSOR=$'\033[?25l'
    printf '%s' "$_HIDE_CURSOR"
    tput civis 2>/dev/null || true
    if [[ -w /dev/tty ]]; then
        printf '%s' "$_HIDE_CURSOR" >/dev/tty
        tput civis >/dev/tty 2>/dev/null || true
    fi

    # ── 临时文件：渲染到文件再一次性输出，避免"先 clear 再慢渲染"闪烁 ──
    local tmp
    tmp=$(mktemp 2>/dev/null || echo "/tmp/foxwaf-status-$$")
    trap '_status_live_cleanup; rm -f "$tmp"; exit 0' INT TERM HUP
    trap '_status_live_cleanup; rm -f "$tmp"'         EXIT

    # ── 首帧：清屏到顶（\033[2J 清整屏 + \033[H 光标回左上）──
    # 之前的 bug 在这里：只在循环里用相对回跳（\033[<N>A），但如果上一帧因终端高度不够而滚屏，
    # 后续回跳就会落到错误位置，造成 banner 累加。改用绝对清屏 + 一次性渲染缓冲，无副作用。
    printf '\033[2J\033[H'
    do_status 2>/dev/null >"$tmp"
    cat "$tmp"
    printf "  ${DM}Ctrl+C 退出  ·  每 0.5s 刷新${N}\n"

    # ── 刷新循环（每帧绝对清屏 + 一次性输出，避免行数差异/滚屏导致的累加）──
    while true; do
        sleep 0.5
        # 采集新内容（先写到 tmp，避免边采集边渲染的撕裂感）
        do_status 2>/dev/null >"$tmp"
        # 绝对清屏到左上：终端再大或再小、frame 高度变化 都不会留残影
        printf '\033[H\033[2J'
        # 一次性 cat：终端绘制开销最低
        cat "$tmp"
        printf "  ${DM}Ctrl+C 退出  ·  每 0.5s 刷新${N}\n"
    done
}

case "${1:-}" in
    start)     do_start ;;
    stop)      do_stop ;;
    restart)   do_restart ;;
    status)    do_status_live ;;
    logs)      do_logs ;;
    update)    shift; do_update "$@" ;;
    export)    do_export ;;
    import)    do_import "${2:-}" ;;
    reset-auth|--reset-auth) do_reset_auth "${2:-fox}" "${3:-}" ;;
    uninstall) do_uninstall ;;
    version|-v|--version) do_version ;;
    -h|--help|help) show_help ;;
    *)         show_help; exit 1 ;;
esac
