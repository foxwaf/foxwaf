#!/bin/bash
# update.sh：对所有远程先 fetch，再把当前分支 push 到各远程

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

REMOTES=$(git remote)

if [ -z "$REMOTES" ]; then
    echo -e "${RED}❌ 没有找到任何远程仓库${NC}"
    exit 1
fi

CURRENT_BRANCH=$(git branch --show-current 2>/dev/null || true)

echo -e "${BLUE}════════════════════════════════════════════${NC}"
echo -e "${BLUE}   正在从所有远程仓库获取更新 (fetch)...${NC}"
echo -e "${BLUE}════════════════════════════════════════════${NC}"
echo ""
echo -e "${YELLOW}📡 远程列表:${NC}"
echo "$REMOTES"
echo ""

for remote in $REMOTES; do
    echo -e "${GREEN}▶ fetch: ${remote}${NC}"
    if git fetch --prune "$remote" 2>&1; then
        echo -e "${GREEN}  ✅ ${remote} fetch 成功${NC}"
    else
        echo -e "${RED}  ❌ ${remote} fetch 失败${NC}"
    fi
    echo ""
done

echo -e "${BLUE}════════════════════════════════════════════${NC}"
echo -e "${GREEN}✅ 所有远程 fetch 完成${NC}"
echo ""

if [ -z "$CURRENT_BRANCH" ]; then
    echo -e "${YELLOW}⚠️  当前为 detached HEAD，跳过 push${NC}"
else
    echo -e "${BLUE}════════════════════════════════════════════${NC}"
    echo -e "${BLUE}   正在将分支 ${CURRENT_BRANCH} 推送到各远程 (push)...${NC}"
    echo -e "${BLUE}════════════════════════════════════════════${NC}"
    echo ""

    for remote in $REMOTES; do
        echo -e "${GREEN}▶ push: ${remote} → ${CURRENT_BRANCH}${NC}"
        if git push "$remote" "$CURRENT_BRANCH" 2>&1; then
            echo -e "${GREEN}  ✅ ${remote} push 成功${NC}"
        else
            echo -e "${RED}  ❌ ${remote} push 失败（可稍后单独: git push ${remote} ${CURRENT_BRANCH}）${NC}"
        fi
        echo ""
    done

    echo -e "${BLUE}════════════════════════════════════════════${NC}"
    echo -e "${GREEN}✅ push 阶段结束${NC}"
    echo ""
fi

echo -e "${YELLOW}📍 当前分支: ${CURRENT_BRANCH:-<detached>}${NC}"
echo ""
echo -e "${BLUE}📊 本地分支状态:${NC}"
git status -sb
echo ""
echo -e "${YELLOW}💡 若需先合并远程再推: git pull <remote> ${CURRENT_BRANCH:-main} 后再执行本脚本${NC}"
