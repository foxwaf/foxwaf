do_export() {
    log_step "导出备份"
    local bdir="${INSTALL_DIR}/backup"; mkdir -p "$bdir"
    local ts; ts=$(date +%Y%m%d_%H%M%S)
    local bf="${bdir}/foxwaf-${ts}.tar.gz"
    local tmp; tmp=$(mktemp -d)

    if is_docker && docker inspect "$CONTAINER" &>/dev/null; then
        local snap_tag="foxwaf/export:${ts}"
        log_dim "容器快照 docker commit → ${snap_tag}"
        if ! docker commit -m "foxwaf export ${ts}" "$CONTAINER" "$snap_tag" &>/dev/null; then
            rm -rf "$tmp"
            log_err "docker commit 失败"
            return 1
        fi
        log_dim "docker save 快照（可能较慢）..."
        if ! docker save "$snap_tag" -o "${tmp}/container-snapshot.tar" 2>/dev/null; then
            docker rmi "$snap_tag" &>/dev/null || true
            rm -rf "$tmp"
            log_err "docker save 失败"
            return 1
        fi
        printf '%s\n' "$snap_tag" > "${tmp}/export-image-tag"
        for f in docker-compose.yml docker-compose.yaml .version; do
            [[ -f "${INSTALL_DIR}/${f}" ]] && cp -a "${INSTALL_DIR}/${f}" "$tmp/"
        done
        log_dim "包内: container-snapshot.tar、export-image-tag、compose、.version"
    else
        for f in conf.yaml source.enc waf .version docker-compose.yml docker-compose.yaml; do
            [[ -f "${INSTALL_DIR}/${f}" ]] && cp -a "${INSTALL_DIR}/${f}" "$tmp/"
        done
        for d in data certificates plugins; do
            [[ -d "${INSTALL_DIR}/${d}" ]] && cp -a "${INSTALL_DIR}/${d}" "$tmp/"
        done
        shopt -s nullglob
        for db in "${INSTALL_DIR}"/*.db; do
            [[ -f "$db" ]] && cp -a "$db" "$tmp/"
        done
        shopt -u nullglob

        if is_docker; then
            log_warn "容器不存在，无法快照；已备份安装目录内文件"
            local cf img
            cf=$(_compose_file)
            if [[ -n "$cf" ]] && img=$(grep -m1 '^[[:space:]]*image:' "$cf" 2>/dev/null | sed 's/^[[:space:]]*image:[[:space:]]*//;s/[[:space:]]*$//;s/^["'\'']//;s/["'\'']$//'); then
                log_dim "附加 docker save 基础镜像: ${img}"
                docker save "$img" -o "${tmp}/docker-image.tar" 2>/dev/null &
                if ! spinner $! "docker save"; then
                    printf "\r%60s\r" ""
                    log_warn "基础镜像导出失败"
                else
                    printf "\r%60s\r" ""
                fi
            fi
        fi
    fi

    tar -czf "$bf" -C "$tmp" . &>/dev/null
    rm -rf "$tmp"
    local sz; sz=$(du -sh "$bf" | awk '{print $1}')
    log_ok "备份已保存"
    log_dim "${bf}  (${sz})"
}

do_import() {
    local bf="${1:-}"
    if [[ -z "$bf" ]]; then
        bf=$(ls -t "${INSTALL_DIR}/backup"/foxwaf-*.tar.gz 2>/dev/null | head -1)
        [[ -z "$bf" ]] && { log_err "用法: foxwaf import <备份文件路径>"; return 1; }
        log_info "自动选择最新备份"
        log_dim "$bf"
    fi
    [[ ! -f "$bf" ]] && { log_err "文件不存在: $bf"; return 1; }

    log_step "恢复备份"
    log_warn "当前数据将被覆盖"
    confirm "确认恢复？" || { log_dim "已取消"; return 0; }

    do_stop 2>/dev/null

    local tmp; tmp=$(mktemp -d)
    tar -xzf "$bf" -C "$tmp"
    mkdir -p "$INSTALL_DIR"

    if [[ -f "${tmp}/container-snapshot.tar" && -f "${tmp}/export-image-tag" ]]; then
        local snap_tag
        snap_tag=$(tr -d '\r\n' <"${tmp}/export-image-tag")
        log_dim "docker load 容器快照..."
        if ! docker load -i "${tmp}/container-snapshot.tar" &>/dev/null; then
            rm -rf "$tmp"
            log_err "快照 docker load 失败"
            return 1
        fi
        [[ -f "${tmp}/docker-compose.yml" ]] && cp -a "${tmp}/docker-compose.yml" "${INSTALL_DIR}/"
        [[ -f "${tmp}/docker-compose.yaml" ]] && cp -a "${tmp}/docker-compose.yaml" "${INSTALL_DIR}/"
        [[ -f "${tmp}/.version" ]] && cp -a "${tmp}/.version" "${INSTALL_DIR}/"
        docker rm -f "$CONTAINER" 2>/dev/null || true
        _compose_set_image "${INSTALL_DIR}/docker-compose.yml" "$snap_tag"
        _compose_set_image "${INSTALL_DIR}/docker-compose.yaml" "$snap_tag"
        rm -rf "$tmp"
        log_ok "已从容器快照恢复  ${DM}image: ${snap_tag}${N}"
        _gap
        do_start
        return 0
    fi

    shopt -s dotglob
    for item in "$tmp"/*; do
        local name; name=$(basename "$item")
        [[ "$name" == "docker-image.tar" ]] && continue
        [[ "$name" == "container-snapshot.tar" ]] && continue
        [[ "$name" == "export-image-tag" ]] && continue
        cp -a "$item" "${INSTALL_DIR}/"
    done
    shopt -u dotglob

    mkdir -p "${INSTALL_DIR}/data"

    if [[ -f "${tmp}/docker-image.tar" ]]; then
        docker load -i "${tmp}/docker-image.tar" &>/dev/null &
        if spinner $! "导入镜像"; then
            printf "\r%60s\r" ""
            log_ok "镜像已导入"
        else
            printf "\r%60s\r" ""
            log_warn "镜像导入失败"
        fi
    fi

    chmod 755 "${INSTALL_DIR}/waf" 2>/dev/null || true
    rm -rf "$tmp"
    log_ok "数据已恢复"
    _gap
    do_start
}

