# ── 入口 ─────────────────────────────────────────────────────────
[[ ! -d "$INSTALL_DIR" ]] && { log_err "未找到安装目录: ${INSTALL_DIR}"; exit 1; }

do_status_live() {
    trap 'tput cnorm 2>/dev/null; exit 0' INT TERM
    tput civis 2>/dev/null
    local tmp; tmp=$(mktemp 2>/dev/null || echo "/tmp/foxwaf-status-$$")
    while true; do
        # 在同一 shell 内采集并渲染到临时文件，避免命令替换子进程导致缓存丢失，
        # 同时避免先 clear 再慢渲染带来的“闪一下/空一会儿”。
        do_status 2>&1 >"$tmp"
        tput clear 2>/dev/null || printf "\033[H\033[2J"
        cat "$tmp"
        printf "  ${DM}Ctrl+C 退出  ·  实时刷新${N}\n"
        sleep 0.5
    done
}

case "${1:-}" in
    start)     do_start ;;
    stop)      do_stop ;;
    restart)   do_restart ;;
    status)    do_status_live ;;
    logs)      do_logs ;;
    update)    do_update ;;
    export)    do_export ;;
    import)    do_import "${2:-}" ;;
    uninstall) do_uninstall ;;
    version|-v|--version) do_version ;;
    -h|--help|help) show_help ;;
    *)         show_help; exit 1 ;;
esac
