set -o pipefail

INSTALL_DIR="/data/foxwaf"
CONTAINER="foxwaf"
FOXWAF_SERVER="${FOXWAF_SERVER:-server.foxwaf.cn}"

# ── 色彩系统 ─────────────────────────────────────────────────────
R=$'\033[38;5;203m'  G=$'\033[38;5;114m'  Y=$'\033[38;5;221m'  C=$'\033[38;5;75m'
M=$'\033[38;5;183m'  W=$'\033[38;5;252m'  DM=$'\033[38;5;243m' D=$'\033[2m'
B=$'\033[1m'         U=$'\033[4m'         N=$'\033[0m'
BG_OK=$'\033[48;5;22m'  BG_ERR=$'\033[48;5;52m'  BG_WARN=$'\033[48;5;58m'
IS_TTY=false
[[ -t 1 ]] && IS_TTY=true

# ── 输出组件 ─────────────────────────────────────────────────────
_line() { printf "  ${DM}%s${N}\n" "$(printf '─%.0s' {1..58})"; }
_gap()  { echo ""; }

log_ok()   { printf "  ${G}●${N}  %b\n" "$*"; }
log_err()  { printf "  ${R}●${N}  %b\n" "$*"; }
log_warn() { printf "  ${Y}●${N}  %b\n" "$*"; }
log_info() { printf "  ${C}◆${N}  %b\n" "$*"; }
log_dim()  { printf "     ${DM}%b${N}\n" "$*"; }

log_step() {
    _gap
    printf "  ${C}${B}▸ %s${N}\n" "$*"
    _gap
}

log_kv() {
    local k="$1" v="$2"
    printf "  ${DM}%-10s${N} %b\n" "$k" "$v"
}

_show_cursor() {
    tput cnorm 2>/dev/null || true
    printf '\033[?25h'
    if [[ -w /dev/tty ]]; then
        tput cnorm >/dev/tty 2>/dev/null || true
        printf '\033[?25h' >/dev/tty 2>/dev/null || true
    fi
}

spinner() {
    local pid=$1 msg="${2:-}"
    local frames=('⣾' '⣽' '⣻' '⢿' '⡿' '⣟' '⣯' '⣷') i=0
    _spinner_on_int() {
        trap - INT EXIT
        _show_cursor
        exit 130
    }
    trap '_spinner_on_int' INT
    trap '_show_cursor; trap - INT EXIT' EXIT
    tput civis 2>/dev/null
    while kill -0 "$pid" 2>/dev/null; do
        printf "\r  ${M}%s${N}  ${DM}%s${N}  " "${frames[$i]}" "$msg"
        i=$(( (i+1) % ${#frames[@]} ))
        sleep 0.1
    done
    trap - INT EXIT
    _show_cursor
    wait "$pid" 2>/dev/null
    return $?
}

progress_bar() {
    local cur=$1 tot=$2 label="${3:-}" w=30
    [[ "$IS_TTY" != "true" ]] && return 0
    (( tot <= 0 )) && return 0
    local pct=$((cur*100/tot))
    (( pct > 100 )) && pct=100
    local filled=$((cur*w/tot))
    (( filled > w )) && filled=$w
    local empty=$((w-filled))
    local bar=""
    for ((i=0;i<filled;i++)); do bar+="█"; done
    for ((i=0;i<empty;i++)); do bar+="░"; done
    printf "\r\033[2K  ${DM}·${N}  ${DM}%-12s${N} ${C}%s${N} ${DM}%3d%%${N}" "$label" "$bar" "$pct"
}

probe_total_size() {
    local url="$1" sz=""
    sz=$(curl -fsSL --range 0-0 --connect-timeout 10 -m 15 -D - -o /dev/null "$url" 2>/dev/null \
        | awk 'BEGIN{IGNORECASE=1;ok=0} /^HTTP\// {ok=($2>=200&&$2<300);next} ok&&/^content-range:/ {n=split($0,a,"/"); v=a[n]; gsub(/[^0-9]/,"",v); if(v!="")last=v} END{print last}')
    if [[ -n "$sz" && "$sz" =~ ^[0-9]+$ && "$sz" -gt 0 ]]; then
        echo "$sz"; return 0
    fi
    sz=$(curl -fsSI -L --connect-timeout 10 -m 15 "$url" 2>/dev/null \
        | awk 'BEGIN{IGNORECASE=1;ok=0} /^HTTP\// {ok=($2>=200&&$2<300);next} ok&&/^content-length:/ {v=$2; gsub(/[^0-9]/,"",v); if(v!="")last=v} END{print last}')
    if [[ -n "$sz" && "$sz" =~ ^[0-9]+$ && "$sz" -gt 0 ]]; then
        echo "$sz"; return 0
    fi
    return 1
}

download_with_progress() {
    local url="$1" dest="$2" label="${3:-下载中}"
    local tmpfile="${dest}.tmp" attempt total_size dl_pid cur_size ret
    for attempt in 1 2 3; do
        rm -f "$tmpfile"
        total_size=$(probe_total_size "$url") || total_size=""
        if [[ -n "$total_size" && "$total_size" -gt 0 ]] 2>/dev/null; then
            if [[ "$IS_TTY" == "true" ]]; then
                curl -fSL --connect-timeout 15 --max-time 600 -o "$tmpfile" "$url" 2>/dev/null &
                dl_pid=$!
                while kill -0 "$dl_pid" 2>/dev/null; do
                    [[ -f "$tmpfile" ]] && cur_size=$(stat -c%s "$tmpfile" 2>/dev/null || echo 0) && progress_bar "$cur_size" "$total_size" "$label"
                    sleep 0.3
                done
                wait "$dl_pid" 2>/dev/null
                ret=$?
                if [[ $ret -eq 0 ]]; then
                    progress_bar "$total_size" "$total_size" "$label"
                    echo ""
                    mv "$tmpfile" "$dest"
                    return 0
                fi
            else
                log_dim "${label} ($((total_size / 1024 / 1024)) MB)..."
                if curl -fSL --connect-timeout 15 --max-time 600 -o "$tmpfile" "$url" 2>/dev/null; then
                    mv "$tmpfile" "$dest"
                    return 0
                fi
            fi
        else
            curl -fSL --connect-timeout 15 --max-time 600 -o "$tmpfile" "$url" 2>/dev/null &
            spinner $! "$label"
            ret=$?
            if [[ $ret -eq 0 && -f "$tmpfile" ]]; then
                [[ "$IS_TTY" == "true" ]] && echo ""
                mv "$tmpfile" "$dest"
                return 0
            fi
        fi
        rm -f "$tmpfile"
        [[ "$attempt" -lt 3 ]] && sleep $((attempt * 2))
    done
    return 1
}

confirm() {
    local msg="${1:-确认操作}"
    printf "  ${Y}?${N}  %s ${DM}[y/N]${N} " "$msg"
    read -r c
    [[ "$c" == "y" || "$c" == "Y" ]]
}

is_docker() { [[ -f "${INSTALL_DIR}/docker-compose.yml" || -f "${INSTALL_DIR}/docker-compose.yaml" ]]; }

# ════════════════════════════════════════════════════════════════════════════
# 版本来源（多层兜底）
# ----------------------------------------------------------------------------
# 历史问题：foxwaf version 与 foxwaf update "当前版本" 都读 ${INSTALL_DIR}/.version，
# 但容器内 binary 经 in-process 更新后真实版本会与该文件错位（最严重时差 5 个 beta），
# 导致 update 把容器降级到更老版本。
#
# 现在所有"当前版本"取值都走 _live_version()，优先级：
#   1. /app/history/current（容器内）或 ${INSTALL_DIR}/history/current（裸机）
#   2. 通过 docker exec 读容器内 .version（兜底）
#   3. ${INSTALL_DIR}/.version（最后兜底，可能漂移）
# ════════════════════════════════════════════════════════════════════════════

# _live_version 返回 binary 真实运行版本。容器未运行时回退到本地文件并附标记。
# 输出格式：'1.53beta'（成功）或 '1.48beta@stale'（fallback 标记）或空（完全失败）
_live_version() {
    local v=""
    if is_docker; then
        if docker inspect "$CONTAINER" &>/dev/null && \
           [[ "$(docker inspect "$CONTAINER" --format '{{.State.Running}}' 2>/dev/null)" == "true" ]]; then
            v=$(docker exec "$CONTAINER" cat /app/history/current 2>/dev/null | tr -d '[:space:]')
            if [[ -z "$v" ]]; then
                # 容器在跑但 history/current 缺失：尝试 .version
                v=$(docker exec "$CONTAINER" cat /app/.version 2>/dev/null | tr -d '[:space:]')
            fi
            [[ -n "$v" ]] && { echo "$v"; return 0; }
        fi
    elif [[ -f "${INSTALL_DIR}/history/current" ]]; then
        v=$(cat "${INSTALL_DIR}/history/current" 2>/dev/null | tr -d '[:space:]')
        [[ -n "$v" ]] && { echo "$v"; return 0; }
    fi
    # 兜底：本地 .version 文件，但加 @stale 标记便于上层警告
    if [[ -f "${INSTALL_DIR}/.version" ]]; then
        v=$(cat "${INSTALL_DIR}/.version" 2>/dev/null | tr -d '[:space:]')
        [[ -n "$v" ]] && { echo "${v}@stale"; return 0; }
    fi
    echo ""
}

# _live_version_clean 去掉 @stale 后缀的版本号
_live_version_clean() {
    local v="$1"
    echo "${v%@stale}"
}

# _is_stale 判断版本字符串是否是 fallback 来源
_is_stale() { [[ "$1" == *"@stale" ]]; }

# _image_version 返回 docker image 名 :tag 中的版本部分；裸机或无 tag 时返回空
_image_version() {
    is_docker || return 0
    docker inspect "$CONTAINER" --format '{{.Config.Image}}' 2>/dev/null | \
        awk -F: '{print $NF}' | grep -E '^[0-9]+\.' || true
}

# ════════════════════════════════════════════════════════════════════════════
# 语义化版本比较（支持 1.53beta、2.0.1 这类 tag）
# 返回：0 = a == b，1 = a > b，-1 = a < b
# 算法：取每段开头连续数字（1.53beta → [1,53]，2.0.1 → [2,0,1]），逐段比较；
# 段数不同时短的补 0；纯数字相等且只有一边带 beta/alpha/rc 后缀视为后缀方更小（pre-release）。
# ════════════════════════════════════════════════════════════════════════════
_compare_version() {
    local a="$1" b="$2"
    [[ "$a" == "$b" ]] && { echo 0; return; }

    # 解析数字段
    local -a aa bb
    IFS='.' read -ra _at <<< "$a"
    IFS='.' read -ra _bt <<< "$b"

    local i n=${#_at[@]} m=${#_bt[@]}
    local maxlen=$(( n > m ? n : m ))
    local has_pre_a=0 has_pre_b=0

    for (( i=0; i<maxlen; i++ )); do
        local pa="${_at[i]:-0}" pb="${_bt[i]:-0}"
        local na nb
        # 提取段开头数字
        na=$(echo "$pa" | grep -oE '^[0-9]+' || echo 0)
        nb=$(echo "$pb" | grep -oE '^[0-9]+' || echo 0)
        # 是否带 beta/alpha/rc 等 pre-release 后缀
        [[ "$pa" =~ [a-zA-Z]+ ]] && has_pre_a=1
        [[ "$pb" =~ [a-zA-Z]+ ]] && has_pre_b=1
        if (( na > nb )); then echo 1; return; fi
        if (( na < nb )); then echo -1; return; fi
    done
    # 数字段全相同：带 pre-release 的版本视为更小（1.53 > 1.53beta）
    if (( has_pre_a == 1 && has_pre_b == 0 )); then echo -1; return; fi
    if (( has_pre_a == 0 && has_pre_b == 1 )); then echo 1; return; fi
    echo 0
}

_ensure_compose_db_volume() {
    :
}

_write_docker_compose() {
    local f="$1" image="$2"
    [[ -z "$f" ]] && f="${INSTALL_DIR}/docker-compose.yml"
    [[ -z "$image" ]] && image="foxwaf:latest"
    mkdir -p "$(dirname "$f")" "${INSTALL_DIR}/data"
    cat > "$f" << DEOF
services:
  foxwaf:
    image: ${image}
    container_name: foxwaf
    restart: unless-stopped
    network_mode: host
    volumes:
      - ./conf.yaml:/app/conf.yaml
      - ./data:/app/data
DEOF
}

_preserve_runtime_conf() {
    mkdir -p "$INSTALL_DIR"
    if [[ -d "${INSTALL_DIR}/conf.yaml" ]]; then
        local bad="${INSTALL_DIR}/conf.yaml.bad.$(date +%Y%m%d%H%M%S)"
        mv "${INSTALL_DIR}/conf.yaml" "$bad" 2>/dev/null || true
        log_warn "检测到 conf.yaml 是目录，已移到 ${bad}"
    fi
    if [[ -f "${INSTALL_DIR}/conf.yaml" && -s "${INSTALL_DIR}/conf.yaml" ]]; then
        log_dim "保留配置: ${INSTALL_DIR}/conf.yaml"
        return 0
    fi
    if docker inspect "$CONTAINER" &>/dev/null; then
        if docker cp "${CONTAINER}:/app/conf.yaml" "${INSTALL_DIR}/conf.yaml" 2>/dev/null && [[ -f "${INSTALL_DIR}/conf.yaml" && -s "${INSTALL_DIR}/conf.yaml" ]]; then
            log_ok "已保存当前配置 conf.yaml"
            return 0
        fi
    fi
    log_err "未找到可持久化的 conf.yaml，已中止，避免账号/入口/端口回默认"
    log_dim "请先执行 foxwaf start 后重试，或手动放置 ${INSTALL_DIR}/conf.yaml"
    return 1
}

_install_cli_update() {
    local src="$1" dst
    [[ -s "$src" ]] || return 0
    head -1 "$src" | grep -q '^#!/bin/bash' || return 0
    dst=$(command -v foxwaf 2>/dev/null || true)
    [[ -z "$dst" ]] && dst="/usr/local/bin/foxwaf"
    cp -f "$src" "$dst" 2>/dev/null || return 0
    chmod +x "$dst" 2>/dev/null || true
    sed -i "s|^INSTALL_DIR=.*|INSTALL_DIR=\"${INSTALL_DIR}\"|" "$dst" 2>/dev/null || true
    log_dim "管理工具已同步: ${dst}"
}

_compose_set_image() {
    local f="$1" img="$2"
    [[ -f "$f" ]] || return 0
    grep -q '^[[:space:]]*image:' "$f" 2>/dev/null || return 0
    sed -i "s|^\([[:space:]]*\)image:.*|\1image: ${img}|" "$f"
}

_compose_file() {
    if [[ -f "${INSTALL_DIR}/docker-compose.yml" ]]; then echo "${INSTALL_DIR}/docker-compose.yml"
    elif [[ -f "${INSTALL_DIR}/docker-compose.yaml" ]]; then echo "${INSTALL_DIR}/docker-compose.yaml"
    fi
}

