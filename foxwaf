MIRRORS_GITHUB="https://github.com/foxwaf/foxwaf"

_dl() {
    local file="$1" dest="$2" ver="$3"
    local url try
    url="${MIRRORS_GITHUB}/releases/download/v${ver}/${file}"
    for try in 1 2 3; do
        if curl -fSL --connect-timeout 15 --max-time 300 -o "$dest" "$url" 2>/dev/null; then
            log_dim "来源: GitHub"
            return 0
        fi
        [[ "$try" -lt 3 ]] && sleep $((try * 2))
    done
    local fb="http://${FOXWAF_SERVER}:8080/release/${ver}/${file}"
    for try in 1 2 3; do
        if curl -fSL --connect-timeout 15 --max-time 300 -o "$dest" "$fb" 2>/dev/null; then
            log_dim "来源: 服务端直连"
            return 0
        fi
        [[ "$try" -lt 3 ]] && sleep $((try * 2))
    done
    return 1
}

_md5ok() {
    local file="$1" md5f="$2"
    [[ ! -f "$md5f" ]] && return 0
    local e a
    e=$(awk '{print $1}' "$md5f" | tr '[:upper:]' '[:lower:]')
    a=$(md5sum "$file" | awk '{print $1}')
    [[ "$e" == "$a" ]]
}

do_update() {
    log_step "检查更新"
    local cv="0.0.0"
    [[ -f "${INSTALL_DIR}/.version" ]] && cv=$(cat "${INSTALL_DIR}/.version")
    log_dim "当前版本: ${cv}"

    local resp
    local _uc="http://${FOXWAF_SERVER}:8080/api/update/check"
    _fw_prepare_dns "$_uc"
    resp=$(curl -s --connect-timeout 10 "${_FW_CURL_DNS[@]}" -X POST "$_uc" \
        -H "Content-Type: application/json" \
        -d "{\"currentVersion\":\"${cv}\"}" 2>/dev/null) || true
    [[ -z "$resp" ]] && { log_err "无法连接更新服务器"; return 1; }

    local hu
    hu=$(echo "$resp" | grep -oP '"hasUpdate"\s*:\s*\K(true|false)' | head -1)
    if [[ "$hu" != "true" ]]; then
        log_ok "已是最新版本 ${B}${cv}${N}"
        return 0
    fi

    local nv ft
    nv=$(echo "$resp" | grep -oP '"version"\s*:\s*"[^"]*"' | head -1 | grep -oP '"[^"]*"$' | tr -d '"')
    ft=$(echo "$resp" | grep -oP '"features"\s*:\s*"[^"]*"' | head -1 | grep -oP '"[^"]*"$' | tr -d '"')

    _gap
    printf "  ${C}${B}╭─────────────────────────────────────────╮${N}\n"
    printf "  ${C}${B}│${N}  ${G}⬆${N}  新版本可用: ${B}%-24s${C}${B}│${N}\n" "$nv"
    [[ -n "$ft" ]] && \
    printf "  ${C}${B}│${N}     ${DM}%-36s${N}${C}${B}│${N}\n" "$ft"
    printf "  ${C}${B}│${N}     ${DM}当前: %-30s${N}${C}${B}│${N}\n" "$cv"
    printf "  ${C}${B}╰─────────────────────────────────────────╯${N}\n"
    _gap

    confirm "立即更新？" || { log_dim "已取消"; return 0; }

    local tmp; tmp=$(mktemp -d)

    log_step "下载 Docker 镜像"
    if _dl "foxwaf-image.tar.gz" "${tmp}/img.tar.gz" "$nv"; then
        _dl "foxwaf-image.tar.gz.md5" "${tmp}/img.md5" "$nv" 2>/dev/null || true
        if _md5ok "${tmp}/img.tar.gz" "${tmp}/img.md5"; then
            log_ok "校验通过"
            log_step "安装更新"
            docker load -i "${tmp}/img.tar.gz" &>/dev/null &
            if spinner $! "导入镜像"; then
                printf "\r%60s\r" ""
            fi
            _dl "docker-compose.yaml" "${INSTALL_DIR}/docker-compose.yml" "$nv" 2>/dev/null || true
            cd "$INSTALL_DIR" && docker compose down &>/dev/null || docker stop "$CONTAINER" &>/dev/null || true
            docker rm "$CONTAINER" &>/dev/null || true
            echo "$nv" > "${INSTALL_DIR}/.version"
            cd "$INSTALL_DIR" && docker compose up -d &>/dev/null &
            spinner $! "启动新版本" && printf "\r%60s\r" ""
            _gap
            log_ok "更新完成  ${DM}${cv} → ${G}${B}${nv}${N}"
        else
            log_err "校验失败，已中止"
        fi
    else
        log_err "下载失败"
    fi
    rm -rf "$tmp"
}

