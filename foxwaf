#!/bin/bash
# ╔═══════════════════════════════════════════════════════════════╗
# ║  FoxWAF — Lightweight High-Performance Web Application Firewall  ║
# ╚═══════════════════════════════════════════════════════════════╝

set -o pipefail

INSTALL_DIR="/data/foxwaf"
CONTAINER="foxwaf"
FOXWAF_SERVER="${FOXWAF_SERVER:-server.foxwaf.cn}"

# ── 色彩系统 ─────────────────────────────────────────────────────
R=$'\033[38;5;203m'  G=$'\033[38;5;114m'  Y=$'\033[38;5;221m'  C=$'\033[38;5;75m'
M=$'\033[38;5;183m'  W=$'\033[38;5;252m'  DM=$'\033[38;5;243m' D=$'\033[2m'
B=$'\033[1m'         U=$'\033[4m'         N=$'\033[0m'
BG_OK=$'\033[48;5;22m'  BG_ERR=$'\033[48;5;52m'  BG_WARN=$'\033[48;5;58m'

# ── 输出组件 ─────────────────────────────────────────────────────
_line() { printf "  ${DM}%s${N}\n" "$(printf '─%.0s' {1..58})"; }
_gap()  { echo ""; }

log_ok()   { printf "  ${G}●${N}  %b\n" "$*"; }
log_err()  { printf "  ${R}●${N}  %b\n" "$*"; }
log_warn() { printf "  ${Y}●${N}  %b\n" "$*"; }
log_info() { printf "  ${C}◆${N}  %b\n" "$*"; }
log_dim()  { printf "     ${DM}%b${N}\n" "$*"; }

log_step() {
    _gap
    printf "  ${C}${B}▸ %s${N}\n" "$*"
    _gap
}

log_kv() {
    local k="$1" v="$2"
    printf "  ${DM}%-10s${N} %b\n" "$k" "$v"
}

spinner() {
    local pid=$1 msg="${2:-}"
    local frames=('⣾' '⣽' '⣻' '⢿' '⡿' '⣟' '⣯' '⣷') i=0
    tput civis 2>/dev/null
    while kill -0 "$pid" 2>/dev/null; do
        printf "\r  ${M}%s${N}  ${DM}%s${N}  " "${frames[$i]}" "$msg"
        i=$(( (i+1) % ${#frames[@]} ))
        sleep 0.1
    done
    tput cnorm 2>/dev/null
    wait "$pid" 2>/dev/null
    return $?
}

progress_bar() {
    local cur=$1 tot=$2 label="${3:-}" w=30
    (( tot == 0 )) && tot=1
    local pct=$((cur*100/tot)) filled=$((cur*w/tot)) empty=$((w-filled))
    local bar=""
    for ((i=0;i<filled;i++)); do bar+="━"; done
    for ((i=0;i<empty;i++)); do bar+="╌"; done
    printf "\r  ${DM}%s${N}  ${C}%s${DM}%s${N}  ${W}%3d%%${N}" "$label" "${bar:0:$filled}" "${bar:$filled}" "$pct"
}

confirm() {
    local msg="${1:-确认操作}"
    printf "  ${Y}?${N}  %s ${DM}[y/N]${N} " "$msg"
    read -r c
    [[ "$c" == "y" || "$c" == "Y" ]]
}

is_docker() { [[ -f "${INSTALL_DIR}/docker-compose.yml" || -f "${INSTALL_DIR}/docker-compose.yaml" ]]; }

_compose_file() {
    if [[ -f "${INSTALL_DIR}/docker-compose.yml" ]]; then echo "${INSTALL_DIR}/docker-compose.yml"
    elif [[ -f "${INSTALL_DIR}/docker-compose.yaml" ]]; then echo "${INSTALL_DIR}/docker-compose.yaml"
    fi
}

# ╔═══════════════════════════════════════════════════════════════╗
# ║  核心命令                                                      ║
# ╚═══════════════════════════════════════════════════════════════╝

do_start() {
    log_step "启动 FoxWAF"
    if is_docker; then
        cd "$INSTALL_DIR" && docker compose up -d &>/dev/null &
        if spinner $! "启动容器"; then
            printf "\r%60s\r" ""
            log_ok "容器已启动"
        else
            printf "\r%60s\r" ""
            log_err "启动失败"
            return 1
        fi
    else
        cd "$INSTALL_DIR" && nohup ./waf > waf.log 2>&1 &
        echo $! > "${INSTALL_DIR}/waf.pid"
        sleep 1
        if kill -0 "$(cat "${INSTALL_DIR}/waf.pid" 2>/dev/null)" 2>/dev/null; then
            log_ok "进程已启动 ${DM}PID $(cat "${INSTALL_DIR}/waf.pid")${N}"
        else
            log_err "启动失败 → ${U}${INSTALL_DIR}/waf.log${N}"
            return 1
        fi
    fi
}

do_stop() {
    log_step "停止 FoxWAF"
    if is_docker; then
        cd "$INSTALL_DIR" && docker compose down &>/dev/null &
        if spinner $! "停止容器"; then
            printf "\r%60s\r" ""
            log_ok "已停止"
        else
            printf "\r%60s\r" ""
            docker stop "$CONTAINER" &>/dev/null
            log_ok "已停止"
        fi
    else
        if [[ -f "${INSTALL_DIR}/waf.pid" ]]; then
            kill "$(cat "${INSTALL_DIR}/waf.pid")" 2>/dev/null || true
            rm -f "${INSTALL_DIR}/waf.pid"
        fi
        pkill -f "${INSTALL_DIR}/waf" 2>/dev/null || true
        log_ok "已停止"
    fi
}

do_restart() {
    do_stop 2>/dev/null
    sleep 1
    do_start
}

_bar() {
    local val=$1 max=$2 w=${3:-20} fill_c="${4:-$C}" empty_c="${5:-$DM}"
    (( max == 0 )) && max=1
    local filled=$(( val * w / max ))
    (( val > 0 && filled == 0 )) && filled=1
    (( filled > w )) && filled=$w
    local empty=$(( w - filled ))
    local bar_f="" bar_e=""
    for ((i=0;i<filled;i++)); do bar_f+="█"; done
    for ((i=0;i<empty;i++)); do bar_e+="░"; done
    printf "%b%s%b%s%b" "$fill_c" "$bar_f" "$empty_c" "$bar_e" "$N"
}

_human_bytes() {
    local bytes=$1
    if (( bytes >= 1073741824 )); then
        awk "BEGIN{printf \"%.1f GB\", $bytes/1073741824}"
    elif (( bytes >= 1048576 )); then
        awk "BEGIN{printf \"%.1f MB\", $bytes/1048576}"
    elif (( bytes >= 1024 )); then
        awk "BEGIN{printf \"%.1f KB\", $bytes/1024}"
    else
        echo "${bytes} B"
    fi
}

do_status() {
    local ver="unknown"
    [[ -f "${INSTALL_DIR}/.version" ]] && ver=$(cat "${INSTALL_DIR}/.version")
    local mode="Bare Metal"; is_docker && mode="Docker"

    local running=false state_txt="Stopped" state_color="$R"
    local uptime="" container_id="" waf_pid=""
    local cpu_pct=0 mem_used=0 mem_limit=0 mem_pct=0 mem_str="" cpu_str=""
    local net_rx=0 net_tx=0 net_rx_str="" net_tx_str=""
    local conns=0 port="" entry="" img_name="" img_size=""

    port=$(awk '/^\s*Port:/{print $2; exit}' "${INSTALL_DIR}/conf.yaml" 2>/dev/null)
    entry=$(awk '/^\s*secureentry:/{print $2; exit}' "${INSTALL_DIR}/conf.yaml" 2>/dev/null)
    [[ -z "$port" ]] && port=8088

    if is_docker; then
        local raw
        raw=$(docker ps --filter "name=${CONTAINER}" --format '{{.Status}}|{{.ID}}' 2>/dev/null)
        if [[ -n "$raw" ]] && echo "$raw" | grep -qi "up"; then
            running=true; state_txt="Running"; state_color="$G"
            container_id=$(echo "$raw" | cut -d'|' -f2)
            uptime=$(docker ps --filter "name=${CONTAINER}" --format '{{.RunningFor}}' 2>/dev/null)
            img_name=$(docker inspect "$CONTAINER" --format '{{.Config.Image}}' 2>/dev/null)
            img_size=$(docker image inspect "$img_name" --format '{{.Size}}' 2>/dev/null)
            [[ -n "$img_size" ]] && img_size=$(_human_bytes "$img_size")

            local stats
            stats=$(docker stats "$CONTAINER" --no-stream --format '{{.CPUPerc}}|{{.MemUsage}}|{{.MemPerc}}|{{.NetIO}}' 2>/dev/null)
            if [[ -n "$stats" ]]; then
                cpu_str=$(echo "$stats" | cut -d'|' -f1 | tr -d ' ')
                local cpu_raw
                cpu_raw=$(echo "$cpu_str" | tr -d '%')
                cpu_pct=$(echo "$cpu_raw" | cut -d'.' -f1)
                [[ -z "$cpu_pct" ]] && cpu_pct=0
                if (( cpu_pct == 0 )) && [[ "$cpu_raw" =~ \.[0-9]*[1-9] ]]; then cpu_pct=1; fi
                mem_str=$(echo "$stats" | cut -d'|' -f2 | sed 's| *||g')
                local mem_pct_raw
                mem_pct_raw=$(echo "$stats" | cut -d'|' -f3 | tr -d ' %')
                mem_pct=$(echo "$mem_pct_raw" | cut -d'.' -f1)
                [[ -z "$mem_pct" ]] && mem_pct=0
                if (( mem_pct == 0 )) && [[ "$mem_pct_raw" =~ \.[0-9]*[1-9] ]]; then mem_pct=1; fi
                local net_io
                net_io=$(echo "$stats" | cut -d'|' -f4 | sed 's| *||g')
                net_rx_str=$(echo "$net_io" | cut -d'/' -f1)
                net_tx_str=$(echo "$net_io" | cut -d'/' -f2)
            fi

            waf_pid=$(docker inspect "$CONTAINER" --format '{{.State.Pid}}' 2>/dev/null)
        fi
    else
        [[ -f "${INSTALL_DIR}/waf.pid" ]] && waf_pid=$(cat "${INSTALL_DIR}/waf.pid")
        if [[ -n "$waf_pid" ]] && kill -0 "$waf_pid" 2>/dev/null; then
            running=true; state_txt="Running"; state_color="$G"
            cpu_str=$(ps -p "$waf_pid" -o %cpu= 2>/dev/null | tr -d ' ')
            cpu_pct=$(echo "$cpu_str" | cut -d'.' -f1)
            [[ -n "$cpu_str" ]] && cpu_str="${cpu_str}%"
            local rss_kb
            rss_kb=$(ps -p "$waf_pid" -o rss= 2>/dev/null | tr -d ' ')
            if [[ -n "$rss_kb" ]]; then
                mem_used=$((rss_kb * 1024))
                mem_str=$(_human_bytes "$mem_used")
                local total_kb
                total_kb=$(awk '/^MemTotal:/{print $2}' /proc/meminfo 2>/dev/null)
                [[ -n "$total_kb" ]] && mem_limit=$((total_kb * 1024)) && mem_pct=$((rss_kb * 100 / total_kb))
            fi
            local elapsed
            elapsed=$(ps -p "$waf_pid" -o etimes= 2>/dev/null | tr -d ' ')
            if [[ -n "$elapsed" ]]; then
                if (( elapsed >= 86400 )); then uptime="$((elapsed/86400))d $((elapsed%86400/3600))h"
                elif (( elapsed >= 3600 )); then uptime="$((elapsed/3600))h $((elapsed%3600/60))m"
                elif (( elapsed >= 60 )); then uptime="$((elapsed/60))m $((elapsed%60))s"
                else uptime="${elapsed}s"
                fi
            fi
        fi
    fi

    if [[ "$running" == "true" ]]; then
        local live_ver=""
        if is_docker; then
            live_ver=$(docker exec "$CONTAINER" cat /app/history/current 2>/dev/null | tr -d '[:space:]')
        elif [[ -f "${INSTALL_DIR}/history/current" ]]; then
            live_ver=$(cat "${INSTALL_DIR}/history/current" 2>/dev/null | tr -d '[:space:]')
        fi
        [[ -n "$live_ver" ]] && ver="$live_ver"
        conns=$(ss -tnp 2>/dev/null | grep -c ":${port} " 2>/dev/null || echo 0)
    fi

    # ── header ──
    _gap
    printf "  ${C}${B}╭──────────────────────────────────────────────────╮${N}\n"
    printf "  ${C}${B}│${N}                                                  ${C}${B}│${N}\n"
    printf "  ${C}${B}│${N}   ${B}◈  FoxWAF${N}  ${DM}Web Application Firewall${N}          ${C}${B}│${N}\n"
    printf "  ${C}${B}│${N}                                                  ${C}${B}│${N}\n"
    printf "  ${C}${B}╰──────────────────────────────────────────────────╯${N}\n"
    _gap

    # ── service ──
    printf "  ${C}${B}▎${N} ${W}${B}SERVICE${N}\n"
    _gap
    printf "    ${DM}Status${N}      ${state_color}●${N} ${state_color}${B}${state_txt}${N}\n"
    printf "    ${DM}Version${N}     ${B}${ver}${N}\n"
    printf "    ${DM}Mode${N}        ${W}${mode}${N}\n"
    [[ -n "$uptime" ]] && \
    printf "    ${DM}Uptime${N}      ${W}${uptime}${N}\n"
    if is_docker; then
        [[ -n "$container_id" ]] && \
        printf "    ${DM}Container${N}   ${DM}${container_id}${N}\n"
        [[ -n "$img_name" ]] && \
        printf "    ${DM}Image${N}       ${DM}${img_name}${N}  ${DM}(${img_size:-?})${N}\n"
    else
        [[ -n "$waf_pid" ]] && \
        printf "    ${DM}PID${N}         ${DM}${waf_pid}${N}\n"
    fi
    printf "    ${DM}Directory${N}   ${DM}${INSTALL_DIR}${N}\n"
    _gap

    if [[ "$running" == "true" ]]; then
        # ── resources ──
        printf "  ${C}${B}▎${N} ${W}${B}RESOURCES${N}\n"
        _gap

        local cpu_bar_color="$G"
        (( cpu_pct > 50 )) && cpu_bar_color="$Y"
        (( cpu_pct > 80 )) && cpu_bar_color="$R"
        printf "    ${DM}CPU${N}     $(_bar "$cpu_pct" 100 20 "$cpu_bar_color")  ${W}%s${N}\n" "${cpu_str:-0%}"

        if [[ -n "$mem_str" ]]; then
            local mem_bar_color="$G"
            (( mem_pct > 50 )) && mem_bar_color="$Y"
            (( mem_pct > 80 )) && mem_bar_color="$R"
            printf "    ${DM}Memory${N}  $(_bar "$mem_pct" 100 20 "$mem_bar_color")  ${W}%s${N}  ${DM}(%s%%)${N}\n" "$mem_str" "$mem_pct"
        fi
        _gap

        # ── network ──
        printf "  ${C}${B}▎${N} ${W}${B}NETWORK${N}\n"
        _gap
        printf "    ${DM}Listen${N}      ${C}:${port}${N}  ${DM}(HTTP)${N}\n"
        printf "    ${DM}Conns${N}       ${W}${conns}${N} ${DM}active${N}\n"
        if [[ -n "$net_rx_str" ]]; then
            printf "    ${DM}Traffic${N}     ${G}▼${N} ${W}${net_rx_str}${N}  ${R}▲${N} ${W}${net_tx_str}${N}\n"
        fi
        _gap
    fi

    # ── panel ──
    printf "  ${C}${B}▎${N} ${W}${B}PANEL${N}\n"
    _gap
    local url="http://localhost:${port}/${entry:-fox}"
    printf "    ${DM}URL${N}         ${C}${U}${url}${N}\n"
    printf "    ${DM}Port${N}        ${W}${port}${N}\n"
    _gap
}

do_logs() {
    if is_docker; then
        docker logs -f --tail 100 "$CONTAINER" 2>/dev/null || \
            (cd "$INSTALL_DIR" && docker compose logs -f --tail 100)
    else
        [[ -f "${INSTALL_DIR}/waf.log" ]] && tail -f -n 100 "${INSTALL_DIR}/waf.log" || log_err "日志文件不存在"
    fi
}

# ╔═══════════════════════════════════════════════════════════════╗
# ║  数据管理                                                      ║
# ╚═══════════════════════════════════════════════════════════════╝

do_export() {
    log_step "导出备份"
    local bdir="${INSTALL_DIR}/backup"; mkdir -p "$bdir"
    local ts; ts=$(date +%Y%m%d_%H%M%S)
    local bf="${bdir}/foxwaf-${ts}.tar.gz"
    local tmp; tmp=$(mktemp -d)

    for f in conf.yaml source.enc waf .version docker-compose.yml docker-compose.yaml; do
        [[ -f "${INSTALL_DIR}/${f}" ]] && cp -a "${INSTALL_DIR}/${f}" "$tmp/"
    done
    for d in data certificates plugins; do
        [[ -d "${INSTALL_DIR}/${d}" ]] && cp -a "${INSTALL_DIR}/${d}" "$tmp/"
    done
    for db in "${INSTALL_DIR}"/*.db; do
        [[ -f "$db" ]] && cp -a "$db" "$tmp/"
    done

    if is_docker; then
        log_dim "导出 Docker 镜像（可能较慢）..."
        local img; img=$(docker inspect "$CONTAINER" --format '{{.Config.Image}}' 2>/dev/null)
        if [[ -n "$img" ]]; then
            docker save "$img" -o "${tmp}/docker-image.tar" 2>/dev/null &
            if spinner $! "打包镜像"; then
                printf "\r%60s\r" ""
            else
                printf "\r%60s\r" ""
                log_warn "镜像导出失败，配置数据不受影响"
            fi
        fi
    fi

    tar -czf "$bf" -C "$tmp" . &>/dev/null
    rm -rf "$tmp"
    local sz; sz=$(du -sh "$bf" | awk '{print $1}')
    log_ok "备份已保存"
    log_dim "${bf}  (${sz})"
}

do_import() {
    local bf="${1:-}"
    if [[ -z "$bf" ]]; then
        bf=$(ls -t "${INSTALL_DIR}/backup"/foxwaf-*.tar.gz 2>/dev/null | head -1)
        [[ -z "$bf" ]] && { log_err "用法: foxwaf import <备份文件路径>"; return 1; }
        log_info "自动选择最新备份"
        log_dim "$bf"
    fi
    [[ ! -f "$bf" ]] && { log_err "文件不存在: $bf"; return 1; }

    log_step "恢复备份"
    log_warn "当前数据将被覆盖"
    confirm "确认恢复？" || { log_dim "已取消"; return 0; }

    do_stop 2>/dev/null

    local tmp; tmp=$(mktemp -d)
    tar -xzf "$bf" -C "$tmp"
    mkdir -p "$INSTALL_DIR"

    shopt -s dotglob
    for item in "$tmp"/*; do
        local name; name=$(basename "$item")
        [[ "$name" == "docker-image.tar" ]] && continue
        cp -a "$item" "${INSTALL_DIR}/"
    done
    shopt -u dotglob

    if [[ -f "${tmp}/docker-image.tar" ]]; then
        docker load -i "${tmp}/docker-image.tar" &>/dev/null &
        if spinner $! "导入镜像"; then
            printf "\r%60s\r" ""
            log_ok "镜像已导入"
        else
            printf "\r%60s\r" ""
            log_warn "镜像导入失败"
        fi
    fi

    chmod 755 "${INSTALL_DIR}/waf" 2>/dev/null || true
    rm -rf "$tmp"
    log_ok "数据已恢复"
    _gap
    do_start
}

# ╔═══════════════════════════════════════════════════════════════╗
# ║  更新系统                                                      ║
# ╚═══════════════════════════════════════════════════════════════╝

MIRRORS_GITHUB="https://github.com/kabubu/foxwaf"
MIRRORS_GITCODE="https://gitcode.com/kabubu/foxwaf"
MIRRORS_GITEE="https://gitee.com/kabubu/foxwaf"
MIRRORS_GITLAB="https://gitlab.com/kabubu/foxwaf"

_build_url() {
    local repo="$1" ver="$2" file="$3" plat="$4" tag="v${ver}"
    case "$plat" in
        gitcode) local p="${repo#*gitcode.com/}"; p="${p%/}"
                 echo "https://api.gitcode.com/api/v5/repos/${p}/releases/${tag}/attach_files/${file}/download" ;;
        gitlab)  echo "${repo}/-/releases/${tag}/downloads/${file}" ;;
        *)       echo "${repo}/releases/download/${tag}/${file}" ;;
    esac
}

_dl() {
    local file="$1" dest="$2" ver="$3"
    local mirrors=(gitcode github gitee gitlab)
    for m in "${mirrors[@]}"; do
        local repo=""
        case $m in
            github)  repo="$MIRRORS_GITHUB" ;;
            gitcode) repo="$MIRRORS_GITCODE" ;;
            gitee)   repo="$MIRRORS_GITEE" ;;
            gitlab)  repo="$MIRRORS_GITLAB" ;;
        esac
        [[ -z "$repo" ]] && continue
        local url; url=$(_build_url "$repo" "$ver" "$file" "$m")
        if curl -fSL --connect-timeout 15 --max-time 300 -o "$dest" "$url" 2>/dev/null; then
            log_dim "来源: ${m}"
            return 0
        fi
    done
    local fb="http://${FOXWAF_SERVER}:8080/release/${ver}/${file}"
    if curl -fSL --connect-timeout 15 --max-time 300 -o "$dest" "$fb" 2>/dev/null; then
        log_dim "来源: 服务端直连"
        return 0
    fi
    return 1
}

_md5ok() {
    local file="$1" md5f="$2"
    [[ ! -f "$md5f" ]] && return 0
    local e a
    e=$(awk '{print $1}' "$md5f" | tr '[:upper:]' '[:lower:]')
    a=$(md5sum "$file" | awk '{print $1}')
    [[ "$e" == "$a" ]]
}

do_update() {
    log_step "检查更新"
    local cv="0.0.0"
    [[ -f "${INSTALL_DIR}/.version" ]] && cv=$(cat "${INSTALL_DIR}/.version")
    log_dim "当前版本: ${cv}"

    local resp
    resp=$(curl -s --connect-timeout 10 -X POST "http://${FOXWAF_SERVER}:8080/api/update/check" \
        -H "Content-Type: application/json" \
        -d "{\"currentVersion\":\"${cv}\"}" 2>/dev/null) || true
    [[ -z "$resp" ]] && { log_err "无法连接更新服务器"; return 1; }

    local hu
    hu=$(echo "$resp" | grep -oP '"hasUpdate"\s*:\s*\K(true|false)' | head -1)
    if [[ "$hu" != "true" ]]; then
        log_ok "已是最新版本 ${B}${cv}${N}"
        return 0
    fi

    local nv ft
    nv=$(echo "$resp" | grep -oP '"version"\s*:\s*"[^"]*"' | head -1 | grep -oP '"[^"]*"$' | tr -d '"')
    ft=$(echo "$resp" | grep -oP '"features"\s*:\s*"[^"]*"' | head -1 | grep -oP '"[^"]*"$' | tr -d '"')

    _gap
    printf "  ${C}${B}╭─────────────────────────────────────────╮${N}\n"
    printf "  ${C}${B}│${N}  ${G}⬆${N}  新版本可用: ${B}%-24s${C}${B}│${N}\n" "$nv"
    [[ -n "$ft" ]] && \
    printf "  ${C}${B}│${N}     ${DM}%-36s${N}${C}${B}│${N}\n" "$ft"
    printf "  ${C}${B}│${N}     ${DM}当前: %-30s${N}${C}${B}│${N}\n" "$cv"
    printf "  ${C}${B}╰─────────────────────────────────────────╯${N}\n"
    _gap

    confirm "立即更新？" || { log_dim "已取消"; return 0; }

    local tmp; tmp=$(mktemp -d)

    if is_docker; then
        log_step "下载 Docker 镜像"
        if _dl "foxwaf-image.tar.gz" "${tmp}/img.tar.gz" "$nv"; then
            _dl "foxwaf-image.tar.gz.md5" "${tmp}/img.md5" "$nv" 2>/dev/null || true
            if _md5ok "${tmp}/img.tar.gz" "${tmp}/img.md5"; then
                log_ok "校验通过"
                log_step "安装更新"
                docker load -i "${tmp}/img.tar.gz" &>/dev/null &
                if spinner $! "导入镜像"; then
                    printf "\r%60s\r" ""
                fi
                _dl "docker-compose.yaml" "${INSTALL_DIR}/docker-compose.yml" "$nv" 2>/dev/null || true
                _dl "waf" "${INSTALL_DIR}/waf" "$nv" 2>/dev/null || true
                _dl "source.enc" "${INSTALL_DIR}/source.enc" "$nv" 2>/dev/null || true
                chmod 755 "${INSTALL_DIR}/waf" 2>/dev/null || true
                do_stop 2>/dev/null
                echo "$nv" > "${INSTALL_DIR}/.version"
                do_start
                _gap
                log_ok "更新完成  ${DM}${cv} → ${G}${B}${nv}${N}"
            else
                log_err "校验失败，已中止"
            fi
        else
            log_err "下载失败"
        fi
    else
        log_step "下载新版本"
        cp "${INSTALL_DIR}/waf" "${INSTALL_DIR}/waf.bak" 2>/dev/null || true
        cp "${INSTALL_DIR}/source.enc" "${INSTALL_DIR}/source.enc.bak" 2>/dev/null || true
        if _dl "waf" "${tmp}/waf" "$nv" && _dl "source.enc" "${tmp}/source.enc" "$nv"; then
            _dl "waf.md5" "${tmp}/waf.md5" "$nv" 2>/dev/null || true
            _dl "source.enc.md5" "${tmp}/src.md5" "$nv" 2>/dev/null || true
            local allok=true
            _md5ok "${tmp}/waf" "${tmp}/waf.md5" || allok=false
            _md5ok "${tmp}/source.enc" "${tmp}/src.md5" || allok=false
            if [[ "$allok" == "true" ]]; then
                log_ok "校验通过"
                log_step "安装更新"
                do_stop 2>/dev/null
                cp "${tmp}/waf" "${INSTALL_DIR}/waf"; chmod 755 "${INSTALL_DIR}/waf"
                cp "${tmp}/source.enc" "${INSTALL_DIR}/source.enc"
                echo "$nv" > "${INSTALL_DIR}/.version"
                do_start
                _gap
                log_ok "更新完成  ${DM}${cv} → ${G}${B}${nv}${N}"
                rm -f "${INSTALL_DIR}/waf.bak" "${INSTALL_DIR}/source.enc.bak"
            else
                log_err "校验失败，正在回滚..."
                mv "${INSTALL_DIR}/waf.bak" "${INSTALL_DIR}/waf" 2>/dev/null || true
                mv "${INSTALL_DIR}/source.enc.bak" "${INSTALL_DIR}/source.enc" 2>/dev/null || true
                log_ok "已回滚到旧版本"
            fi
        else
            log_err "下载失败"
            rm -f "${INSTALL_DIR}/waf.bak" "${INSTALL_DIR}/source.enc.bak"
        fi
    fi
    rm -rf "$tmp"
}

