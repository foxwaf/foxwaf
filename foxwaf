set -o pipefail

INSTALL_DIR="/data/foxwaf"
CONTAINER="foxwaf"
FOXWAF_SERVER="${FOXWAF_SERVER:-server.foxwaf.cn}"

# ── 色彩系统 ─────────────────────────────────────────────────────
R=$'\033[38;5;203m'  G=$'\033[38;5;114m'  Y=$'\033[38;5;221m'  C=$'\033[38;5;75m'
M=$'\033[38;5;183m'  W=$'\033[38;5;252m'  DM=$'\033[38;5;243m' D=$'\033[2m'
B=$'\033[1m'         U=$'\033[4m'         N=$'\033[0m'
BG_OK=$'\033[48;5;22m'  BG_ERR=$'\033[48;5;52m'  BG_WARN=$'\033[48;5;58m'

# ── 输出组件 ─────────────────────────────────────────────────────
_line() { printf "  ${DM}%s${N}\n" "$(printf '─%.0s' {1..58})"; }
_gap()  { echo ""; }

log_ok()   { printf "  ${G}●${N}  %b\n" "$*"; }
log_err()  { printf "  ${R}●${N}  %b\n" "$*"; }
log_warn() { printf "  ${Y}●${N}  %b\n" "$*"; }
log_info() { printf "  ${C}◆${N}  %b\n" "$*"; }
log_dim()  { printf "     ${DM}%b${N}\n" "$*"; }

log_step() {
    _gap
    printf "  ${C}${B}▸ %s${N}\n" "$*"
    _gap
}

log_kv() {
    local k="$1" v="$2"
    printf "  ${DM}%-10s${N} %b\n" "$k" "$v"
}

spinner() {
    local pid=$1 msg="${2:-}"
    local frames=('⣾' '⣽' '⣻' '⢿' '⡿' '⣟' '⣯' '⣷') i=0
    tput civis 2>/dev/null
    while kill -0 "$pid" 2>/dev/null; do
        printf "\r  ${M}%s${N}  ${DM}%s${N}  " "${frames[$i]}" "$msg"
        i=$(( (i+1) % ${#frames[@]} ))
        sleep 0.1
    done
    tput cnorm 2>/dev/null
    wait "$pid" 2>/dev/null
    return $?
}

progress_bar() {
    local cur=$1 tot=$2 label="${3:-}" w=30
    (( tot == 0 )) && tot=1
    local pct=$((cur*100/tot)) filled=$((cur*w/tot)) empty=$((w-filled))
    local bar=""
    for ((i=0;i<filled;i++)); do bar+="━"; done
    for ((i=0;i<empty;i++)); do bar+="╌"; done
    printf "\r  ${DM}%s${N}  ${C}%s${DM}%s${N}  ${W}%3d%%${N}" "$label" "${bar:0:$filled}" "${bar:$filled}" "$pct"
}

confirm() {
    local msg="${1:-确认操作}"
    printf "  ${Y}?${N}  %s ${DM}[y/N]${N} " "$msg"
    read -r c
    [[ "$c" == "y" || "$c" == "Y" ]]
}

is_docker() { [[ -f "${INSTALL_DIR}/docker-compose.yml" || -f "${INSTALL_DIR}/docker-compose.yaml" ]]; }

_ensure_compose_db_volume() {
    :
}

# 将 compose 中的 image: 行替换为快照镜像（导入 docker commit 备份后使用）
_compose_set_image() {
    local f="$1" img="$2"
    [[ -f "$f" ]] || return 0
    grep -q '^[[:space:]]*image:' "$f" 2>/dev/null || return 0
    sed -i "s|^\([[:space:]]*\)image:.*|\1image: ${img}|" "$f"
}

_compose_file() {
    if [[ -f "${INSTALL_DIR}/docker-compose.yml" ]]; then echo "${INSTALL_DIR}/docker-compose.yml"
    elif [[ -f "${INSTALL_DIR}/docker-compose.yaml" ]]; then echo "${INSTALL_DIR}/docker-compose.yaml"
    fi
}

# ╔═══════════════════════════════════════════════════════════════╗
# ║  核心命令                                                      ║
# ╚═══════════════════════════════════════════════════════════════╝

do_start() {
    log_step "启动 FoxWAF"
    if is_docker; then
        if docker inspect "$CONTAINER" &>/dev/null; then
            docker start "$CONTAINER" &>/dev/null &
        else
            cd "$INSTALL_DIR" && docker compose up -d &>/dev/null &
        fi
        if spinner $! "启动容器"; then
            printf "\r%60s\r" ""
            log_ok "容器已启动"
        else
            printf "\r%60s\r" ""
            log_err "启动失败"
            return 1
        fi
    else
        cd "$INSTALL_DIR" && nohup ./waf > waf.log 2>&1 &
        echo $! > "${INSTALL_DIR}/waf.pid"
        sleep 1
        if kill -0 "$(cat "${INSTALL_DIR}/waf.pid" 2>/dev/null)" 2>/dev/null; then
            log_ok "进程已启动 ${DM}PID $(cat "${INSTALL_DIR}/waf.pid")${N}"
        else
            log_err "启动失败 → ${U}${INSTALL_DIR}/waf.log${N}"
            return 1
        fi
    fi
}

do_stop() {
    log_step "停止 FoxWAF"
    if is_docker; then
        docker stop "$CONTAINER" &>/dev/null &
        if spinner $! "停止容器"; then
            printf "\r%60s\r" ""
            log_ok "已停止"
        else
            printf "\r%60s\r" ""
            docker kill "$CONTAINER" &>/dev/null
            log_ok "已停止"
        fi
    else
        if [[ -f "${INSTALL_DIR}/waf.pid" ]]; then
            kill "$(cat "${INSTALL_DIR}/waf.pid")" 2>/dev/null || true
            rm -f "${INSTALL_DIR}/waf.pid"
        fi
        pkill -f "${INSTALL_DIR}/waf" 2>/dev/null || true
        log_ok "已停止"
    fi
}

do_restart() {
    do_stop 2>/dev/null
    sleep 1
    do_start
}

_bar() {
    local val=$1 max=$2 w=${3:-20} fill_c="${4:-$C}" empty_c="${5:-$DM}"
    (( max == 0 )) && max=1
    local filled=$(( val * w / max ))
    (( val > 0 && filled == 0 )) && filled=1
    (( filled > w )) && filled=$w
    local empty=$(( w - filled ))
    local bar_f="" bar_e=""
    for ((i=0;i<filled;i++)); do bar_f+="█"; done
    for ((i=0;i<empty;i++)); do bar_e+="░"; done
    printf "%b%s%b%s%b" "$fill_c" "$bar_f" "$empty_c" "$bar_e" "$N"
}

_human_bytes() {
    local bytes=$1
    if (( bytes >= 1073741824 )); then
        awk "BEGIN{printf \"%.1f GB\", $bytes/1073741824}"
    elif (( bytes >= 1048576 )); then
        awk "BEGIN{printf \"%.1f MB\", $bytes/1048576}"
    elif (( bytes >= 1024 )); then
        awk "BEGIN{printf \"%.1f KB\", $bytes/1024}"
    else
        echo "${bytes} B"
    fi
}

_parse_human_bytes() {
    # Convert strings like: "0B", "12.3KB", "5.5GB" into bytes (integer).
    local s="$1"
    s=$(echo "${s}" | tr -d ' ')
    [[ -z "$s" ]] && { echo 0; return; }

    local num unit
    if [[ "$s" =~ ^([0-9]+(\.[0-9]+)?)([A-Za-z]+)$ ]]; then
        num="${BASH_REMATCH[1]}"
        unit="${BASH_REMATCH[3]}"
    else
        echo 0
        return
    fi

    unit=$(echo "$unit" | tr '[:lower:]' '[:upper:]')
    local factor=1
    case "$unit" in
        B) factor=1 ;;
        KB|K) factor=1024 ;;
        MB|M) factor=$((1024*1024)) ;;
        GB|G) factor=$((1024*1024*1024)) ;;
        TB|T) factor=$((1024*1024*1024*1024)) ;;
        PB|P) factor=$((1024*1024*1024*1024*1024)) ;;
        *) factor=1 ;;
    esac

    awk "BEGIN{printf \"%.0f\", ${num}*${factor}}"
}

# Cache previous network counters so we can show RX/TX rate (per second).
_NET_LAST_TS_MS=0
_NET_LAST_RX=0
_NET_LAST_TX=0

do_status() {
    local ver="unknown"
    [[ -f "${INSTALL_DIR}/.version" ]] && ver=$(cat "${INSTALL_DIR}/.version")
    local mode="Bare Metal"; is_docker && mode="Docker"

    local running=false state_txt="Stopped" state_color="$R"
    local uptime="" container_id="" waf_pid=""
    local cpu_pct=0 mem_used=0 mem_limit=0 mem_pct=0 mem_str="" cpu_str=""
    local net_rx=0 net_tx=0 net_rx_str="" net_tx_str=""
    local net_rx_rate_b=0 net_tx_rate_b=0 net_rx_rate_str="" net_tx_rate_str=""
    local net_rx_disp="" net_tx_disp=""
    local conns_http=0 conns_https=0 port="" entry="" img_name="" img_size=""

    port=$(awk '/^\s*Port:/{print $2; exit}' "${INSTALL_DIR}/conf.yaml" 2>/dev/null)
    entry=$(awk '/^\s*secureentry:/{print $2; exit}' "${INSTALL_DIR}/conf.yaml" 2>/dev/null)
    [[ -z "$port" ]] && port=8088

    if is_docker; then
        # 必须用精确容器名 inspect，不能用 ps --filter name=（子串匹配会误报其它容器）
        if ! docker inspect "$CONTAINER" &>/dev/null; then
            running=false; state_txt="容器不存在"; state_color="$Y"
        elif [[ "$(docker inspect "$CONTAINER" --format '{{.State.Running}}' 2>/dev/null)" == "true" ]]; then
            local _cid_full
            _cid_full=$(docker inspect "$CONTAINER" --format '{{.Id}}' 2>/dev/null)
            running=true; state_txt="Running"; state_color="$G"
            container_id=$(echo "$_cid_full" | cut -c1-12)
            uptime=$(docker ps --no-trunc --filter "id=${_cid_full}" --format '{{.RunningFor}}' 2>/dev/null | head -1)
            [[ -z "$uptime" ]] && uptime=$(docker inspect "$CONTAINER" --format '{{.State.Status}}' 2>/dev/null)
            img_name=$(docker inspect "$CONTAINER" --format '{{.Config.Image}}' 2>/dev/null)
            img_size=$(docker image inspect "$img_name" --format '{{.Size}}' 2>/dev/null)
            [[ -n "$img_size" ]] && img_size=$(_human_bytes "$img_size")

            waf_pid=$(docker inspect "$CONTAINER" --format '{{.State.Pid}}' 2>/dev/null)

            local cg_base=""
            for _p in "/sys/fs/cgroup/system.slice/docker-${_cid_full}.scope" \
                      "/sys/fs/cgroup/docker/${_cid_full}"; do
                [[ -d "$_p" ]] && { cg_base="$_p"; break; }
            done

            if [[ -n "$cg_base" && -f "${cg_base}/cpu.stat" ]]; then
                local t1 t2 ncpu
                t1=$(awk '/^usage_usec/{print $2}' "${cg_base}/cpu.stat" 2>/dev/null)
                sleep 0.5
                t2=$(awk '/^usage_usec/{print $2}' "${cg_base}/cpu.stat" 2>/dev/null)
                ncpu=$(nproc 2>/dev/null || echo 1)
                if [[ -n "$t1" && -n "$t2" && "$t2" -gt "$t1" ]]; then
                    cpu_str=$(awk "BEGIN{v=($t2-$t1)/5000/$ncpu; printf \"%.2f%%\",v}")
                    cpu_pct=$(awk "BEGIN{printf \"%d\",($t2-$t1)/5000/$ncpu}")
                    [[ -z "$cpu_pct" ]] && cpu_pct=0
                    if (( cpu_pct == 0 )) && (( t2 > t1 )); then cpu_pct=1; fi
                fi

                if [[ -f "${cg_base}/memory.current" ]]; then
                    local mem_bytes mem_total_kb
                    mem_bytes=$(cat "${cg_base}/memory.current" 2>/dev/null)
                    mem_total_kb=$(awk '/^MemTotal:/{print $2}' /proc/meminfo 2>/dev/null)
                    if [[ -n "$mem_bytes" && -n "$mem_total_kb" ]]; then
                        local mem_total_bytes=$((mem_total_kb * 1024))
                        mem_str="$(_human_bytes "$mem_bytes")/$(_human_bytes "$mem_total_bytes")"
                        mem_pct=$((mem_bytes * 100 / mem_total_bytes))
                        (( mem_pct == 0 && mem_bytes > 0 )) && mem_pct=1
                    fi
                fi

                if [[ -n "$waf_pid" && -f "/proc/${waf_pid}/net/dev" ]]; then
                    local net_line
                    net_line=$(awk '/:/{gsub(/:/," "); rx+=$2; tx+=$10} END{print rx, tx}' "/proc/${waf_pid}/net/dev" 2>/dev/null)
                    local rx_b tx_b
                    rx_b=$(echo "$net_line" | awk '{print $1}')
                    tx_b=$(echo "$net_line" | awk '{print $2}')
                    [[ -n "$rx_b" && "$rx_b" -gt 0 ]] && {
                        net_rx=$rx_b
                        # Compact for terminal width consistency (e.g. "5.5GB" instead of "5.5 GB")
                        net_rx_str=$(_human_bytes "$rx_b" | tr -d ' ')
                    }
                    [[ -n "$tx_b" && "$tx_b" -gt 0 ]] && {
                        net_tx=$tx_b
                        net_tx_str=$(_human_bytes "$tx_b" | tr -d ' ')
                    }
                fi
            else
                local stats
                stats=$(timeout 3 docker stats "$CONTAINER" --no-stream --format '{{.CPUPerc}}|{{.MemUsage}}|{{.MemPerc}}|{{.NetIO}}' 2>/dev/null)
                if [[ -n "$stats" ]]; then
                    cpu_str=$(echo "$stats" | cut -d'|' -f1 | tr -d ' ')
                    local cpu_raw
                    cpu_raw=$(echo "$cpu_str" | tr -d '%')
                    cpu_pct=$(echo "$cpu_raw" | cut -d'.' -f1)
                    [[ -z "$cpu_pct" ]] && cpu_pct=0
                    if (( cpu_pct == 0 )) && [[ "$cpu_raw" =~ \.[0-9]*[1-9] ]]; then cpu_pct=1; fi
                    mem_str=$(echo "$stats" | cut -d'|' -f2 | sed 's| *||g')
                    local mem_pct_raw
                    mem_pct_raw=$(echo "$stats" | cut -d'|' -f3 | tr -d ' %')
                    mem_pct=$(echo "$mem_pct_raw" | cut -d'.' -f1)
                    [[ -z "$mem_pct" ]] && mem_pct=0
                    if (( mem_pct == 0 )) && [[ "$mem_pct_raw" =~ \.[0-9]*[1-9] ]]; then mem_pct=1; fi
                    local net_io
                    net_io=$(echo "$stats" | cut -d'|' -f4 | sed 's| *||g')
                    net_rx_str=$(echo "$net_io" | cut -d'/' -f1)
                    net_tx_str=$(echo "$net_io" | cut -d'/' -f2)
                    # docker stats only provides human-readable totals; parse them to compute RX/TX rate.
                    net_rx=$(_parse_human_bytes "$net_rx_str")
                    net_tx=$(_parse_human_bytes "$net_tx_str")
                fi
            fi
        else
            running=false; state_txt="Stopped"; state_color="$R"
            container_id=$(docker inspect "$CONTAINER" --format '{{.Id}}' 2>/dev/null | cut -c1-12)
            img_name=$(docker inspect "$CONTAINER" --format '{{.Config.Image}}' 2>/dev/null)
        fi
    else
        [[ -f "${INSTALL_DIR}/waf.pid" ]] && waf_pid=$(cat "${INSTALL_DIR}/waf.pid")
        if [[ -n "$waf_pid" ]] && kill -0 "$waf_pid" 2>/dev/null; then
            running=true; state_txt="Running"; state_color="$G"
            cpu_str=$(ps -p "$waf_pid" -o %cpu= 2>/dev/null | tr -d ' ')
            cpu_pct=$(echo "$cpu_str" | cut -d'.' -f1)
            [[ -n "$cpu_str" ]] && cpu_str="${cpu_str}%"
            local rss_kb
            rss_kb=$(ps -p "$waf_pid" -o rss= 2>/dev/null | tr -d ' ')
            if [[ -n "$rss_kb" ]]; then
                mem_used=$((rss_kb * 1024))
                mem_str=$(_human_bytes "$mem_used")
                local total_kb
                total_kb=$(awk '/^MemTotal:/{print $2}' /proc/meminfo 2>/dev/null)
                [[ -n "$total_kb" ]] && mem_limit=$((total_kb * 1024)) && mem_pct=$((rss_kb * 100 / total_kb))
            fi
            local elapsed
            elapsed=$(ps -p "$waf_pid" -o etimes= 2>/dev/null | tr -d ' ')
            if [[ -n "$elapsed" ]]; then
                if (( elapsed >= 86400 )); then uptime="$((elapsed/86400))d $((elapsed%86400/3600))h"
                elif (( elapsed >= 3600 )); then uptime="$((elapsed/3600))h $((elapsed%3600/60))m"
                elif (( elapsed >= 60 )); then uptime="$((elapsed/60))m $((elapsed%60))s"
                else uptime="${elapsed}s"
                fi
            fi
        fi
    fi

    if [[ "$running" == "true" ]]; then
        local live_ver=""
        if is_docker; then
            live_ver=$(docker exec "$CONTAINER" cat /app/history/current 2>/dev/null | tr -d '[:space:]')
        elif [[ -f "${INSTALL_DIR}/history/current" ]]; then
            live_ver=$(cat "${INSTALL_DIR}/history/current" 2>/dev/null | tr -d '[:space:]')
        fi
        [[ -n "$live_ver" ]] && ver="$live_ver"
        # WAF 实际入口端口一般是 80/443（容器使用 host network_mode）。
        # 这里拆开统计，避免把它们误当成面板的 8088。
        conns_http=$(ss -tnp 2>/dev/null | awk '$4 ~ /:80$/ || $5 ~ /:80$/ {c++} END{print c+0}' 2>/dev/null || true)
        conns_https=$(ss -tnp 2>/dev/null | awk '$4 ~ /:443$/ || $5 ~ /:443$/ {c++} END{print c+0}' 2>/dev/null || true)
        conns_http=${conns_http:-0}
        conns_https=${conns_https:-0}

        # Compute RX/TX rate when we have raw counters from /proc (bytes).
        if (( net_rx > 0 && net_tx > 0 )); then
            local now_ms dt_ms rx_delta tx_delta
            now_ms=$(date +%s%3N 2>/dev/null || echo $(( $(date +%s) * 1000 )))

            if (( _NET_LAST_TS_MS > 0 )); then
                dt_ms=$(( now_ms - _NET_LAST_TS_MS ))
                if (( dt_ms > 0 )); then
                    rx_delta=$(( net_rx - _NET_LAST_RX ))
                    tx_delta=$(( net_tx - _NET_LAST_TX ))
                    # delta 可能因为 docker stats 的四舍五入而出现轻微负数；
                    # 负数视作 0，避免速率字符串为空导致回退到总量显示。
                    (( rx_delta < 0 )) && rx_delta=0
                    (( tx_delta < 0 )) && tx_delta=0
                    net_rx_rate_b=$(( rx_delta * 1000 / dt_ms ))
                    net_rx_rate_str=$(_human_bytes "$net_rx_rate_b" | tr -d ' ')
                    net_tx_rate_b=$(( tx_delta * 1000 / dt_ms ))
                    net_tx_rate_str=$(_human_bytes "$net_tx_rate_b" | tr -d ' ')
                fi
            fi

            _NET_LAST_TS_MS=$now_ms
            _NET_LAST_RX=$net_rx
            _NET_LAST_TX=$net_tx
        fi

        if [[ -n "$net_rx_rate_str" && -n "$net_tx_rate_str" ]]; then
            net_rx_disp="${net_rx_rate_str}/s"
            net_tx_disp="${net_tx_rate_str}/s"
        else
            net_rx_disp="$net_rx_str"
            net_tx_disp="$net_tx_str"
        fi
    fi

    # ── header ──
    _gap
    printf "  ${C}${B}╭──────────────────────────────────────────────────╮${N}\n"
    printf "  ${C}${B}│${N}                                                  ${C}${B}│${N}\n"
    printf "  ${C}${B}│${N}   ${B}*  FoxWAF${N}  ${DM}Web Application Firewall${N}            ${C}${B}│${N}\n"
    printf "  ${C}${B}│${N}                                                  ${C}${B}│${N}\n"
    printf "  ${C}${B}╰──────────────────────────────────────────────────╯${N}\n"
    _gap

    # ── service ──
    printf "  ${C}${B}▎${N} ${W}${B}SERVICE${N}\n"
    _gap
    printf "    ${DM}Status${N}      ${state_color}●${N} ${state_color}${B}${state_txt}${N}\n"
    if is_docker && [[ "$state_txt" == "容器不存在" ]]; then
        printf "    ${DM}说明${N}        ${DM}compose 在但容器已删；start 将重新创建${N}\n"
    fi
    printf "    ${DM}Version${N}     ${B}${ver}${N}\n"
    printf "    ${DM}Mode${N}        ${W}${mode}${N}\n"
    [[ -n "$uptime" ]] && \
    printf "    ${DM}Uptime${N}      ${W}${uptime}${N}\n"
    if is_docker; then
        [[ -n "$container_id" ]] && \
        printf "    ${DM}Container${N}   ${DM}${container_id}${N}\n"
        [[ -n "$img_name" ]] && \
        printf "    ${DM}Image${N}       ${DM}${img_name}${N}  ${DM}(${img_size:-?})${N}\n"
    else
        [[ -n "$waf_pid" ]] && \
        printf "    ${DM}PID${N}         ${DM}${waf_pid}${N}\n"
    fi
    printf "    ${DM}Directory${N}   ${DM}${INSTALL_DIR}${N}\n"
    _gap

    if [[ "$running" == "true" ]]; then
        # ── resources ──
        printf "  ${C}${B}▎${N} ${W}${B}RESOURCES${N}\n"
        _gap

        local cpu_bar_color="$G"
        (( cpu_pct > 50 )) && cpu_bar_color="$Y"
        (( cpu_pct > 80 )) && cpu_bar_color="$R"
        printf "    ${DM}CPU${N}     $(_bar "$cpu_pct" 100 20 "$cpu_bar_color")  ${W}%s${N}\n" "${cpu_str:-0%}"

        local mem_bar_color="$G"
        (( mem_pct > 50 )) && mem_bar_color="$Y"
        (( mem_pct > 80 )) && mem_bar_color="$R"
        if [[ -n "$mem_str" ]]; then
            printf "    ${DM}Memory${N}  $(_bar "$mem_pct" 100 20 "$mem_bar_color")  ${W}%s${N}  ${DM}(%s%%)${N}\n" "$mem_str" "$mem_pct"
        else
            printf "    ${DM}Memory${N}  $(_bar 0 100 20)  ${DM}--${N}\n"
        fi
        _gap

        # ── network ──
        printf "  ${C}${B}▎${N} ${W}${B}NETWORK${N}\n"
        _gap
        printf "    ${DM}Listen${N}      ${C}:${port}${N}  ${DM}(HTTP)${N}\n"
        printf "    ${DM}Conns80${N}     ${W}${conns_http}${N} ${DM}active${N}\n"
        printf "    ${DM}Conns443${N}    ${W}${conns_https}${N} ${DM}active${N}\n"
        if [[ -n "$net_rx_disp" && -n "$net_tx_disp" ]]; then
            printf "    ${DM}Traffic${N}     ${G}▼${N} ${W}${net_rx_disp}${N}  ${R}▲${N} ${W}${net_tx_disp}${N}\n"
        fi
        _gap
    fi

    # ── panel ──
    printf "  ${C}${B}▎${N} ${W}${B}PANEL${N}\n"
    _gap
    local url="http://localhost:${port}/${entry:-fox}"
    printf "    ${DM}URL${N}         ${C}${U}${url}${N}\n"
    printf "    ${DM}Port${N}        ${W}${port}${N}\n"
    _gap
}

do_logs() {
    if is_docker; then
        docker logs -f --tail 100 "$CONTAINER" 2>/dev/null || \
            (cd "$INSTALL_DIR" && docker compose logs -f --tail 100)
    else
        [[ -f "${INSTALL_DIR}/waf.log" ]] && tail -f -n 100 "${INSTALL_DIR}/waf.log" || log_err "日志文件不存在"
    fi
}

