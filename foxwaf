do_start() {
    log_step "启动 FoxWAF"
    if is_docker; then
        if docker inspect "$CONTAINER" &>/dev/null; then
            docker start "$CONTAINER" &>/dev/null &
        else
            cd "$INSTALL_DIR" && docker compose up -d &>/dev/null &
        fi
        if spinner $! "启动容器"; then
            printf "\r%60s\r" ""
            log_ok "容器已启动"
        else
            printf "\r%60s\r" ""
            log_err "启动失败"
            return 1
        fi
    else
        cd "$INSTALL_DIR" && nohup ./waf > waf.log 2>&1 &
        echo $! > "${INSTALL_DIR}/waf.pid"
        sleep 1
        if kill -0 "$(cat "${INSTALL_DIR}/waf.pid" 2>/dev/null)" 2>/dev/null; then
            log_ok "进程已启动 ${DM}PID $(cat "${INSTALL_DIR}/waf.pid")${N}"
        else
            log_err "启动失败 → ${U}${INSTALL_DIR}/waf.log${N}"
            return 1
        fi
    fi
}

do_stop() {
    log_step "停止 FoxWAF"
    if is_docker; then
        docker stop "$CONTAINER" &>/dev/null &
        if spinner $! "停止容器"; then
            printf "\r%60s\r" ""
            log_ok "已停止"
        else
            printf "\r%60s\r" ""
            docker kill "$CONTAINER" &>/dev/null
            log_ok "已停止"
        fi
    else
        if [[ -f "${INSTALL_DIR}/waf.pid" ]]; then
            kill "$(cat "${INSTALL_DIR}/waf.pid")" 2>/dev/null || true
            rm -f "${INSTALL_DIR}/waf.pid"
        fi
        pkill -f "${INSTALL_DIR}/waf" 2>/dev/null || true
        log_ok "已停止"
    fi
}

do_restart() {
    do_stop 2>/dev/null
    sleep 1
    do_start
}

_rand_secret() {
    local n="${1:-16}"
    tr -dc 'A-Za-z0-9' </dev/urandom 2>/dev/null | head -c "$n"
}

_panel_port() {
    local p
    if is_docker; then
        p=$(docker exec "$CONTAINER" sh -c "awk '/^[[:space:]]*Port:/{print \$2; exit}' /app/conf.yaml" 2>/dev/null)
    else
        p=$(awk '/^\s*Port:/{print $2; exit}' "${INSTALL_DIR}/conf.yaml" 2>/dev/null)
    fi
    [[ -z "$p" ]] && p=8088
    echo "$p"
}

# 读取 WAF 启动时随机生成的 reload token（保存在容器/裸机 /tmp/.foxwaf_reload_token，权限 0600）
_read_reload_token() {
    if is_docker; then
        docker exec "$CONTAINER" cat /tmp/.foxwaf_reload_token 2>/dev/null
    else
        cat /tmp/.foxwaf_reload_token 2>/dev/null
    fi
}

# JSON 转义（仅处理 \ 和 " 与控制字符 \n \r \t）
_json_escape() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

do_reset_auth() {
    local new_user="${1:-fox}"
    local new_pass="${2:-$(_rand_secret 18)}"
    log_step "重置面板认证（无重启热加载）"

    if is_docker; then
        if [[ "$(docker inspect "$CONTAINER" --format '{{.State.Running}}' 2>/dev/null)" != "true" ]]; then
            log_err "容器未运行，无法热重载认证"
            return 1
        fi
    else
        [[ -f "${INSTALL_DIR}/conf.yaml" ]] || { log_err "未找到 conf.yaml"; return 1; }
    fi

    local tok port
    tok="$(_read_reload_token)"
    if [[ -z "$tok" ]]; then
        log_err "无法读取 /tmp/.foxwaf_reload_token —— WAF 是否启动？是否为新版？"
        return 1
    fi
    port="$(_panel_port)"

    local body
    body=$(printf '{"username":"%s","password":"%s"}' "$(_json_escape "$new_user")" "$(_json_escape "$new_pass")")

    # 8088 强制 HTTPS 自签证书 → -k 跳过校验；
    # WAF 内部接口同时更新内存账户与 conf.yaml，口令按 SHA256+salt 保存，无需额外操作。
    # 注意：--resolve + Host: 127.0.0.1 强制走 loopback 直连，
    #       同时显式不带任何 X-Forwarded-* 头，满足 WAF 的本地白名单防护。
    local resp http_code
    resp=$(curl -ksS -o /tmp/.reset_auth_resp.json -w '%{http_code}' \
        --max-time 10 \
        --noproxy '*' \
        --resolve "127.0.0.1:${port}:127.0.0.1" \
        -X POST \
        -H "Host: 127.0.0.1:${port}" \
        -H "X-Reload-Token: ${tok}" \
        -H "Content-Type: application/json" \
        --data "${body}" \
        "https://127.0.0.1:${port}/internal/auth/reload" 2>/dev/null) || {
        log_err "调用 /internal/auth/reload 失败（curl 退出非零）"
        return 1
    }
    http_code="${resp}"

    if [[ "${http_code}" != "200" ]]; then
        log_err "热重载失败：HTTP ${http_code}"
        if [[ -s /tmp/.reset_auth_resp.json ]]; then
            log_dim "服务端响应：$(cat /tmp/.reset_auth_resp.json)"
        fi
        return 1
    fi

    log_ok "认证已热重载（无需重启，业务流量不中断）"
    log_info "新账号: ${B}${new_user}${N}"
    log_info "新密码: ${B}${new_pass}${N}"
    log_dim "面板入口: https://127.0.0.1:${port}/  (自签证书，浏览器需信任例外)"
}

_bar() {
    local val=$1 max=$2 w=${3:-20} fill_c="${4:-$C}" empty_c="${5:-$DM}"
    (( max == 0 )) && max=1
    local filled=$(( val * w / max ))
    (( val > 0 && filled == 0 )) && filled=1
    (( filled > w )) && filled=$w
    local empty=$(( w - filled ))
    local bar_f="" bar_e=""
    for ((i=0;i<filled;i++)); do bar_f+="█"; done
    for ((i=0;i<empty;i++)); do bar_e+="░"; done
    printf "%b%s%b%s%b" "$fill_c" "$bar_f" "$empty_c" "$bar_e" "$N"
}

_human_bytes() {
    local bytes=$1
    if (( bytes >= 1073741824 )); then
        awk "BEGIN{printf \"%.1f GB\", $bytes/1073741824}"
    elif (( bytes >= 1048576 )); then
        awk "BEGIN{printf \"%.1f MB\", $bytes/1048576}"
    elif (( bytes >= 1024 )); then
        awk "BEGIN{printf \"%.1f KB\", $bytes/1024}"
    else
        echo "${bytes} B"
    fi
}

_parse_human_bytes() {
    local s="$1"
    s=$(echo "${s}" | tr -d ' ')
    [[ -z "$s" ]] && { echo 0; return; }

    local num unit
    if [[ "$s" =~ ^([0-9]+(\.[0-9]+)?)([A-Za-z]+)$ ]]; then
        num="${BASH_REMATCH[1]}"
        unit="${BASH_REMATCH[3]}"
    else
        echo 0
        return
    fi

    unit=$(echo "$unit" | tr '[:lower:]' '[:upper:]')
    local factor=1
    case "$unit" in
        B) factor=1 ;;
        KB|K) factor=1024 ;;
        MB|M) factor=$((1024*1024)) ;;
        GB|G) factor=$((1024*1024*1024)) ;;
        TB|T) factor=$((1024*1024*1024*1024)) ;;
        PB|P) factor=$((1024*1024*1024*1024*1024)) ;;
        *) factor=1 ;;
    esac

    awk "BEGIN{printf \"%.0f\", ${num}*${factor}}"
}

