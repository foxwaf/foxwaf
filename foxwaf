    printf "  ${C}${B}╰─────────────────────────────────────────╯${N}\n"
    _gap
    printf "  ${B}用法${N}   foxwaf ${DM}<command>${N}\n"
    _gap
    _line
    _gap
    printf "  ${C}${B}服务${N}\n"
    _gap
    printf "    ${W}start${N}       ${DM}启动服务${N}\n"
    printf "    ${W}stop${N}        ${DM}停止服务${N}\n"
    printf "    ${W}restart${N}     ${DM}重启服务${N}\n"
    printf "    ${W}status${N}      ${DM}运行状态${N}\n"
    printf "    ${W}logs${N}        ${DM}实时日志${N}\n"
    _gap
    printf "  ${C}${B}维护${N}\n"
    _gap
    printf "    ${W}update${N}      ${DM}检查并安装更新${N}\n"
    printf "    ${W}export${N}      ${DM}Docker：容器快照（docker commit+save）；裸机：目录文件${N}\n"
    printf "    ${W}import${N}      ${DM}恢复备份 ${DM}[foxwaf import <file>]${N}\n"
