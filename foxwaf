# ════════════════════════════════════════════════════════════════════════════
# 镜像下载体系（与 waf.go ensureCoreMirrors / downloadFromMirrors 同语义）
#   1. 服务端 /api/update/check 下发 mirrors[]（do_update 阶段写入 MIRRORS_REMOTE）
#   2. 与 MIRRORS_BUILTIN（GitHub/GitCode）按 platform 去重合并，远端优先
#   3. 按 priority + 实测 RTT 排序，依次尝试
#   4. 全部镜像失败 → 回退 https://${FOXWAF_SERVER}/release/<ver>/<file>
# ════════════════════════════════════════════════════════════════════════════

MIRRORS_BUILTIN=(
    "github|GitHub|https://github.com/foxwaf/foxwaf|1"
    "gitcode|GitCode|https://gitcode.com/kabubu/foxwaf|2"
)
MIRRORS_REMOTE=()

_parse_mirrors() {
    local resp="$1"
    MIRRORS_REMOTE=()
    [[ -z "$resp" ]] && return 0
    local arr items item name platform repo priority
    arr=$(echo "$resp" | grep -oP '"mirrors"\s*:\s*\[\K[^\]]*' | head -1)
    [[ -z "$arr" ]] && return 0
    items=$(echo "$arr" | grep -oP '\{[^}]*\}')
    while IFS= read -r item; do
        [[ -z "$item" ]] && continue
        name=$(echo "$item"     | grep -oP '"name"\s*:\s*"\K[^"]*'     | head -1)
        platform=$(echo "$item" | grep -oP '"platform"\s*:\s*"\K[^"]*' | head -1)
        repo=$(echo "$item"     | grep -oP '"repo"\s*:\s*"\K[^"]*'     | head -1)
        priority=$(echo "$item" | grep -oP '"priority"\s*:\s*\K[0-9]+' | head -1)
        [[ -z "$priority" ]] && priority=99
        [[ -z "$repo" ]] && continue
        MIRRORS_REMOTE+=("${platform}|${name}|${repo}|${priority}")
    done <<< "$items"
}

_rtt_ms() {
    local repo="$1" host t
    host=$(echo "$repo" | sed -E 's|^https?://([^/:]+).*|\1|')
    [[ -z "$host" ]] && { echo 9999; return; }
    t=$(curl -o /dev/null -s -m 3 --connect-timeout 2 -w '%{time_connect}' "https://${host}/" 2>/dev/null)
    if [[ -z "$t" || "$t" == "0.000000" ]]; then
        t=$(curl -o /dev/null -s -m 3 --connect-timeout 2 -w '%{time_connect}' "http://${host}/" 2>/dev/null)
    fi
    if [[ -z "$t" || "$t" == "0.000000" ]]; then
        echo 9999
    else
        awk "BEGIN{printf \"%d\", ${t}*1000}"
    fi
}

_build_mirror_url() {
    local platform="$1" repo="$2" version="$3" file="$4"
    repo="${repo%/}"
    case "$platform" in
        gitcode)
            local owner_repo
            owner_repo=$(echo "$repo" | sed -E 's|^https?://[^/]+/||')
            echo "https://api.gitcode.com/api/v5/repos/${owner_repo}/releases/v${version}/attach_files/${file}/download"
            ;;
        gitlab)
            echo "${repo}/-/releases/v${version}/downloads/${file}"
            ;;
        *)
            echo "${repo}/releases/download/v${version}/${file}"
            ;;
    esac
}

_sorted_mirrors() {
    local m p
    local -A seen=()
    local merged=()
    for m in "${MIRRORS_REMOTE[@]}"; do
        p=$(echo "$m" | cut -d'|' -f1 | tr '[:upper:]' '[:lower:]')
        [[ -n "$p" ]] && seen["$p"]=1
        merged+=("$m")
    done
    for m in "${MIRRORS_BUILTIN[@]}"; do
        p=$(echo "$m" | cut -d'|' -f1 | tr '[:upper:]' '[:lower:]')
        [[ -n "${seen[$p]:-}" ]] && continue
        merged+=("$m")
    done
    local entry priority repo rtt sortkey
    for entry in "${merged[@]}"; do
        priority=$(echo "$entry" | cut -d'|' -f4)
        repo=$(echo "$entry"     | cut -d'|' -f3)
        rtt=$(_rtt_ms "$repo")
        sortkey=$(printf '%03d%05d' "${priority:-99}" "$rtt")
        echo "${sortkey}|${entry}"
    done | sort
}

# 单源下载：能探测到大小时显示进度条（复用 probe_total_size/progress_bar），否则回退 spinner
_download_one() {
    local url="$1" dest="$2" label="${3:-下载中}"
    local tmpfile="${dest}.tmp" total_size dl_pid cur_size ret
    rm -f "$tmpfile"

    total_size=$(probe_total_size "$url") || total_size=""
    if [[ "$IS_TTY" == "true" && -n "$total_size" && "$total_size" -gt 0 ]] 2>/dev/null; then
        curl -fSL --connect-timeout 15 --max-time 600 -o "$tmpfile" "$url" 2>/dev/null &
        dl_pid=$!
        while kill -0 "$dl_pid" 2>/dev/null; do
            [[ -f "$tmpfile" ]] && cur_size=$(stat -c%s "$tmpfile" 2>/dev/null || echo 0) && progress_bar "$cur_size" "$total_size" "$label"
            sleep 0.3
        done
        wait "$dl_pid" 2>/dev/null
        ret=$?
        if [[ $ret -eq 0 && -f "$tmpfile" ]]; then
            progress_bar "$total_size" "$total_size" "$label"
            echo ""
            mv "$tmpfile" "$dest"
            return 0
        fi
        rm -f "$tmpfile"
        return 1
    fi

    # 探测不到大小（如镜像跳转 S3 无 Content-Length）或非 TTY：回退 spinner
    curl -fSL --connect-timeout 15 --max-time 600 -o "$tmpfile" "$url" 2>/dev/null &
    spinner $! "$label"
    ret=$?
    if [[ $ret -eq 0 && -f "$tmpfile" ]]; then
        [[ "$IS_TTY" == "true" ]] && echo ""
        mv "$tmpfile" "$dest"
        return 0
    fi
    rm -f "$tmpfile"
    return 1
}

# 替换原 _dl：按 mirrors 排序依次尝试，全失败回退服务端直链
_dl() {
    local file="$1" dest="$2" ver="$3" label="${4:-$1}"
    local entry m platform name repo url
    while IFS= read -r entry; do
        [[ -z "$entry" ]] && continue
        m="${entry#*|}"
        platform=$(echo "$m" | cut -d'|' -f1)
        name=$(echo "$m"     | cut -d'|' -f2)
        repo=$(echo "$m"     | cut -d'|' -f3)
        url=$(_build_mirror_url "$platform" "$repo" "$ver" "$file")
        if _download_one "$url" "$dest" "${label}（${name}）"; then
            return 0
        fi
    done < <(_sorted_mirrors)

    local fb="https://${FOXWAF_SERVER}/release/${ver}/${file}"
    if _download_one "$fb" "$dest" "${label}（服务端）"; then
        return 0
    fi
    return 1
}

_md5ok() {
    local file="$1" md5f="$2"
    [[ ! -f "$md5f" ]] && return 0
    local e a
    e=$(awk '{print $1}' "$md5f" | tr '[:upper:]' '[:lower:]')
    a=$(md5sum "$file" | awk '{print $1}')
    [[ "$e" == "$a" ]]
}

do_update() {
    # 解析可选 --allow-downgrade（B 项要求）
    local allow_downgrade=0
    local arg
    for arg in "$@"; do
        case "$arg" in
            --allow-downgrade|-D) allow_downgrade=1 ;;
        esac
    done

    log_step "检查更新"

    # ── 当前版本：必须用 binary 真实运行版本（A 项），不再用 .version 文件 ──
    local cv_raw cv image_ver
    cv_raw=$(_live_version)
    if [[ -z "$cv_raw" ]]; then
        log_err "无法确定当前版本（容器未启动且无本地 .version）"
        return 1
    fi
    cv=$(_live_version_clean "$cv_raw")
    log_dim "当前版本: ${cv}"

    # ── 镜像 tag 与 binary 漂移检查（静默，不展示给用户）──
    if is_docker && ! _is_stale "$cv_raw"; then
        image_ver=$(_image_version)
    fi

    local resp
    local _uc="https://${FOXWAF_SERVER}/api/update/check"
    resp=$(curl -fsSL --connect-timeout 10 --max-time 20 -X POST "$_uc" \
        -H "Content-Type: application/json" \
        -d "{\"currentVersion\":\"${cv}\"}" 2>/dev/null) || true
    [[ -z "$resp" ]] && { log_err "无法连接更新服务器"; return 1; }

    # 解析服务端下发的 mirrors（与 waf.go 同语义：合并内置 GitHub/GitCode 兜底，按 priority+RTT 排序）
    _parse_mirrors "$resp"
    if [[ ${#MIRRORS_REMOTE[@]} -gt 0 ]]; then
        log_dim "服务端下发 ${#MIRRORS_REMOTE[@]} 个镜像源"
    fi

    local hu
    hu=$(echo "$resp" | grep -oP '"hasUpdate"\s*:\s*\K(true|false)' | head -1)
    if [[ "$hu" != "true" ]]; then
        log_ok "已是最新版本 ${B}${cv}${N}"
        return 0
    fi

    local nv ft
    nv=$(echo "$resp" | grep -oP '"version"\s*:\s*"[^"]*"' | head -1 | grep -oP '"[^"]*"$' | tr -d '"')
    ft=$(echo "$resp" | grep -oP '"features"\s*:\s*"[^"]*"' | head -1 | grep -oP '"[^"]*"$' | tr -d '"')

    # ── 降级护栏（B 项）──
    local cmp; cmp=$(_compare_version "$nv" "$cv")
    if [[ "$cmp" == "0" ]]; then
        log_ok "已是目标版本 ${B}${cv}${N}（远端建议 ${nv}，等价）"
        return 0
    fi
    if [[ "$cmp" == "-1" ]]; then
        if (( allow_downgrade == 1 )); then
            log_warn "降级模式：${cv} → ${nv}（--allow-downgrade 已确认）"
        else
            log_err "拒绝降级：当前 ${cv} 高于远端目标 ${nv}"
            log_dim "如确需降级，重新执行: foxwaf update --allow-downgrade"
            return 1
        fi
    fi

    # 列表形式展示（CJK 字符宽度不定，画框右侧难对齐，改用无框列表）
    _gap
    if [[ "$cmp" == "-1" ]]; then
        printf "  ${R}⬇${N}  ${R}${B}降级${N}  ${DM}${cv}${N} ${DM}→${N} ${R}${B}${nv}${N}\n"
    else
        printf "  ${G}⬆${N}  ${W}${B}新版本可用${N}  ${DM}${cv}${N} ${DM}→${N} ${G}${B}${nv}${N}\n"
    fi
    if [[ -n "$ft" ]]; then
        # 将 JSON 中的 \\n 转义换成真正的换行，逐行展示；read 默认 IFS 去掉行首尾空白
        local line
        while read -r line; do
            [[ -z "$line" ]] && continue
            line="${line//%%/%}"
            printf "       ${DM}•${N} ${DM}%s${N}\n" "$line"
        done < <(echo "$ft" | sed 's/\\n/\n/g')
    fi
    _gap

    confirm "立即更新？" || { log_dim "已取消"; return 0; }

    local tmp; tmp=$(mktemp -d)

    log_step "下载 Docker 镜像"
    if _dl "foxwaf-image.tar.gz" "${tmp}/img.tar.gz" "$nv" "Docker 镜像"; then
        _dl "foxwaf-image.tar.gz.md5" "${tmp}/img.md5" "$nv" "镜像校验" 2>/dev/null || true
        _dl "foxwaf" "${tmp}/foxwaf.new" "$nv" "管理工具" 2>/dev/null || true
        if _md5ok "${tmp}/img.tar.gz" "${tmp}/img.md5"; then
            log_step "安装更新"
            docker load -i "${tmp}/img.tar.gz" &>/dev/null &
            if spinner $! "导入镜像"; then
                printf "\r%60s\r" ""
            fi
            if ! _preserve_runtime_conf; then
                rm -rf "$tmp"
                return 1
            fi
            local compose_f
            compose_f=$(_compose_file)
            [[ -z "$compose_f" ]] && compose_f="${INSTALL_DIR}/docker-compose.yml"
            _write_docker_compose "$compose_f" "foxwaf:${nv}"
            log_dim "配置已持久化: conf.yaml / data"
            cd "$INSTALL_DIR" && docker compose down &>/dev/null || docker stop "$CONTAINER" &>/dev/null || true
            docker rm "$CONTAINER" &>/dev/null || true
            echo "$nv" > "${INSTALL_DIR}/.version"
            cd "$INSTALL_DIR" && docker compose up -d &>/dev/null &
            spinner $! "启动新版本" && printf "\r%60s\r" ""
            _install_cli_update "${tmp}/foxwaf.new"
            _gap
            if [[ "$cmp" == "-1" ]]; then
                log_ok "降级完成  ${DM}${cv} → ${R}${B}${nv}${N}"
            else
                log_ok "更新完成  ${DM}${cv} → ${G}${B}${nv}${N}"
            fi
        else
            log_err "校验失败，已中止"
        fi
    else
        log_err "下载失败"
    fi
    rm -rf "$tmp"
}

